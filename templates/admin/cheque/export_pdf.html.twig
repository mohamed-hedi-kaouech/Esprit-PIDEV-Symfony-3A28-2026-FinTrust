<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Export admin cheques</title>
  <style>
    body { font-family: Arial, sans-serif; color: #1f2937; margin: 24px; }
    h1 { color: #1d4ed8; }
    table { width: 100%; border-collapse: collapse; margin-top: 16px; }
    th, td { border: 1px solid #dbe3ef; padding: 8px; text-align: left; }
    th { background: #eff6ff; }
    .toolbar { margin-bottom: 16px; }
    @media print { .toolbar { display: none; } }
  </style>
</head>
<body>
  <div class="toolbar"><button onclick="window.print()">Imprimer / PDF</button></div>
  <h1>Export admin des cheques</h1>
  <p>Genere le {{ "now"|date("d/m/Y H:i") }}</p>
  <table>
    <thead>
      <tr><th>ID</th><th>Numero</th><th>Beneficiaire</th><th>Montant</th><th>Statut</th><th>Wallet</th><th>Motif rejet</th></tr>
    </thead>
    <tbody>
      {% for cheque in cheques %}
        <tr>
          <td>{{ cheque.idCheque }}</td>
          <td>{{ cheque.numeroCheque }}</td>
          <td>{{ cheque.beneficiaire ?: '-' }}</td>
          <td>{{ cheque.montant }}</td>
          <td>{{ cheque.statut }}</td>
          <td>#{{ cheque.wallet.idWallet }} - {{ cheque.wallet.nomProprietaire }}</td>
          <td>{{ cheque.motifRejet ?: '-' }}</td>
        </tr>
      {% else %}
        <tr><td colspan="7">Aucune demande.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</body>
</html>
