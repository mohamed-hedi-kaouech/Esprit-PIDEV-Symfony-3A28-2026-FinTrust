{% extends 'admin/back.html.twig' %}
{% block title %}Gestion des cheques{% endblock %}

{% block breadcrumb %}
  <a href="{{ path('admin_dashboard') }}" class="text-muted small text-decoration-none">Dashboard</a>
  <i class="bi bi-chevron-right mx-1 text-muted small"></i>
  <span class="fw-semibold small">Gestion des cheques</span>
{% endblock %}

{% block admin_content %}
<section class="ft-admin-hero mb-4">
  <div class="ft-admin-hero-grid">
    <div>
      <span class="ft-admin-hero-kicker">
        <i class="bi bi-journal-check me-1"></i>Workflow admin des cheques
      </span>
      <h1 class="ft-admin-page-title mb-3">Gerer les demandes de cheques</h1>
      <p class="ft-admin-hero-subtitle mb-0">
        Examinez chaque cheque, controlez l etat du wallet associe et appliquez un workflow propre d approbation ou de refus.
      </p>
    </div>
    <div class="ft-admin-hero-panel">
      <div class="d-flex flex-wrap gap-2 justify-content-lg-end mb-3">
        <a href="{{ path('admin_wallet_index') }}" class="btn ft-btn-outline-primary">
          <i class="bi bi-wallet2 me-2"></i>Retour Wallets
        </a>
        <a href="{{ path('admin_cheque_export_csv', {
          numero: filters.numero,
          beneficiaire: filters.beneficiaire,
          statut: filters.statut,
          wallet: filters.wallet
        }) }}" class="btn ft-btn-primary">
          <i class="bi bi-download me-2"></i>Exporter CSV
        </a>
      </div>
      <div class="ft-admin-meta justify-content-lg-end">
        <span><i class="bi bi-list-check"></i>{{ cheques|length }} cheque(s) affiche(s)</span>
      </div>
    </div>
  </div>
</section>

<section class="ft-admin-card mb-4">
  <div class="ft-admin-card-header">
    <i class="bi bi-funnel me-2 text-primary"></i>Recherche et filtres
  </div>
  <div class="ft-admin-card-body">
    <form method="get" action="{{ path('admin_cheque_index') }}" class="row g-3">
      <div class="col-md-3">
        <label class="form-label fw-semibold">Numero cheque</label>
        <input type="text" name="numero" class="form-control ft-input" value="{{ filters.numero }}" placeholder="Ex: CHQ-001">
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold">Beneficiaire</label>
        <input type="text" name="beneficiaire" class="form-control ft-input" value="{{ filters.beneficiaire }}" placeholder="Nom du beneficiaire">
      </div>
      <div class="col-md-2">
        <label class="form-label fw-semibold">Statut</label>
        <select name="statut" class="form-select ft-input">
          <option value="">Tous</option>
          <option value="en_attente" {{ filters.statut == 'en_attente' ? 'selected' : '' }}>En attente</option>
          <option value="accepte" {{ filters.statut == 'accepte' ? 'selected' : '' }}>Accepte</option>
          <option value="refuse" {{ filters.statut == 'refuse' ? 'selected' : '' }}>Refuse</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label fw-semibold">Wallet</label>
        <input type="number" name="wallet" class="form-control ft-input" value="{{ filters.wallet }}" placeholder="ID wallet">
      </div>
      <div class="col-md-2 d-flex align-items-end gap-2">
        <button type="submit" class="btn ft-btn-primary w-100">
          <i class="bi bi-search me-2"></i>Filtrer
        </button>
        <a href="{{ path('admin_cheque_index') }}" class="btn ft-btn-outline-primary w-100">
          <i class="bi bi-arrow-counterclockwise me-2"></i>Reset
        </a>
      </div>
    </form>
  </div>
</section>

<section class="ft-admin-card">
  <div class="ft-admin-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <span><i class="bi bi-table me-2 text-primary"></i>Liste des cheques</span>
    <span class="ft-admin-status-chip ft-admin-status-info">{{ cheques|length }} resultat(s)</span>
  </div>
  <div class="ft-admin-card-body p-0">
    <div class="table-responsive">
      <table class="table ft-admin-table align-middle mb-0">
        <thead>
          <tr>
            <th>ID</th>
            <th>Numero cheque</th>
            <th>Beneficiaire</th>
            <th>Montant</th>
            <th>Statut</th>
            <th>Date emission</th>
            <th>Wallet associe</th>
            <th>Proprietaire wallet</th>
            <th>Wallet bloque</th>
            <th class="text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for cheque in cheques %}
            {% set chequeStatus = cheque.statut|lower %}
            {% set chequeBadge = chequeStatus == 'accepte' ? 'ft-badge-success' : (chequeStatus == 'refuse' ? 'ft-badge-danger' : 'ft-badge-warning') %}
            <tr>
              <td class="fw-bold">#{{ cheque.idCheque }}</td>
              <td>{{ cheque.numeroCheque }}</td>
              <td>{{ cheque.beneficiaire ?: '-' }}</td>
              <td class="fw-semibold">{{ cheque.montant }}</td>
              <td><span class="badge {{ chequeBadge }}">{{ cheque.statut|upper }}</span></td>
              <td>{{ cheque.dateEmission|date('d/m/Y H:i') }}</td>
              <td>
                <a href="{{ path('admin_wallet_show', {id: cheque.wallet.idWallet}) }}" class="text-decoration-none fw-semibold">
                  #{{ cheque.wallet.idWallet }}
                </a>
              </td>
              <td>{{ cheque.wallet.nomProprietaire }}</td>
              <td>
                <span class="badge {{ cheque.wallet.estBloque ? 'ft-badge-danger' : 'ft-badge-success' }}">
                  {{ cheque.wallet.estBloque ? 'Oui' : 'Non' }}
                </span>
              </td>
              <td class="text-center">
                <div class="d-flex flex-wrap justify-content-center gap-2">
                  <a href="{{ path('admin_cheque_show', {id: cheque.idCheque}) }}" class="btn btn-sm ft-btn-outline-primary">
                    <i class="bi bi-eye me-1"></i>Voir
                  </a>

                  {% if chequeStatus == 'en_attente' %}
                    {% if cheque.wallet.estBloque %}
                      <button type="button" class="btn btn-sm btn-outline-secondary" disabled>
                        <i class="bi bi-lock me-1"></i>Wallet bloque
                      </button>
                    {% else %}
                      <form method="post" action="{{ path('admin_cheque_approve', {id: cheque.idCheque}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('approve_cheque_' ~ cheque.idCheque) }}">
                        <button type="submit" class="btn btn-sm btn-outline-success">
                          <i class="bi bi-check2-circle me-1"></i>Approuver
                        </button>
                      </form>
                    {% endif %}

                    <a href="{{ path('admin_cheque_reject', {id: cheque.idCheque}) }}" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-x-circle me-1"></i>Refuser
                    </a>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="10" class="text-center py-5 text-muted">
                Aucune demande de cheque trouvee.
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>
{% endblock %}
