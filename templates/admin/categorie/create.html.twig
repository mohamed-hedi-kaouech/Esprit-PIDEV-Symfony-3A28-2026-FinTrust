{% extends 'admin/back.html.twig' %}

{% block title %}Créer une Catégorie{% endblock %}

{% block admin_content %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="h3 mb-0 text-gray-800">Créer une Nouvelle Catégorie</h1>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            {{ form_start(form) }}
            
            <div class="mb-3">
                {{ form_label(form.nomCategorie, 'Nom de la Catégorie') }}
                {{ form_widget(form.nomCategorie, {'attr': {'class': 'form-control'}}) }}
                {% if form.nomCategorie.vars.errors|length > 0 %}
                    <div class="invalid-feedback d-block">
                        {% for error in form.nomCategorie.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="mb-3">
                {{ form_label(form.budgetPrevu, 'Budget Prévu (€)') }}
                {{ form_widget(form.budgetPrevu, {'attr': {'class': 'form-control'}}) }}
                {% if form.budgetPrevu.vars.errors|length > 0 %}
                    <div class="invalid-feedback d-block">
                        {% for error in form.budgetPrevu.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="mb-3">
                {{ form_label(form.seuilAlerte, 'Seuil d\'Alerte (€)') }}
                {{ form_widget(form.seuilAlerte, {'attr': {'class': 'form-control'}}) }}
                {% if form.seuilAlerte.vars.errors|length > 0 %}
                    <div class="invalid-feedback d-block">
                        {% for error in form.seuilAlerte.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Créer
                </button>
                <a href="{{ path('admin_categorie_list') }}" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Annuler
                </a>
            </div>
            
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
