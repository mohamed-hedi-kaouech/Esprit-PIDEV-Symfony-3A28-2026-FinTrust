{% extends 'admin/base.html.twig' %}

{% block admin_body %}
    <h1>Détails de la catégorie</h1>

    <table style="width:100%; border-collapse: collapse; margin-bottom:1rem;">
        <tbody>
            <tr>
                <th style="text-align:left; padding:0.5rem; border-bottom:1px solid #ddd;">Id</th>
                <td style="padding:0.5rem; border-bottom:1px solid #ddd;">{{ categorie.idCategorie }}</td>
            </tr>
            <tr>
                <th style="text-align:left; padding:0.5rem; border-bottom:1px solid #ddd;">Nom</th>
                <td style="padding:0.5rem; border-bottom:1px solid #ddd;">{{ categorie.nomCategorie }}</td>
            </tr>
            <tr>
                <th style="text-align:left; padding:0.5rem; border-bottom:1px solid #ddd;">Budget prévu</th>
                <td style="padding:0.5rem; border-bottom:1px solid #ddd;">{{ categorie.budgetPrevu }}</td>
            </tr>
            <tr>
                <th style="text-align:left; padding:0.5rem;">Seuil d’alerte</th>
                <td style="padding:0.5rem;">{{ categorie.seuilAlerte }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('admin_categorie_index') }}">Retour à la liste</a>
    <a href="{{ path('admin_categorie_edit', {'id': categorie.idCategorie}) }}">Modifier</a>
    {{ include('admin/categorie/_delete_form.html.twig') }}
{% endblock %}
