<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Connexion Admin - FinTrust</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="{{ asset('css/fintrust-admin.css') }}"/>
</head>
<body class="ft-admin-auth-body">
  <div class="ft-admin-auth-shell">
    <section class="ft-admin-auth-hero">
      <div class="ft-admin-auth-noise"></div>
      <div class="ft-admin-auth-copy">
        <div class="ft-admin-auth-badge">
          <i class="bi bi-shield-lock"></i>
          Espace administrateur FinTrust
        </div>

        <h1 class="ft-admin-auth-title">Pilotez la validation KYC et la plateforme depuis une console claire, rapide et securisee.</h1>
        <p class="ft-admin-auth-text">Accedez au back-office pour approuver les dossiers, suivre les utilisateurs et superviser l'activite FinTrust dans une interface professionnelle.</p>

        <div class="ft-admin-auth-stats">
          <div class="ft-admin-auth-stat">
            <span class="ft-admin-auth-stat-value">KYC</span>
            <span class="ft-admin-auth-stat-label">Validation et controle</span>
          </div>
          <div class="ft-admin-auth-stat">
            <span class="ft-admin-auth-stat-value">Users</span>
            <span class="ft-admin-auth-stat-label">Gestion centralisee</span>
          </div>
          <div class="ft-admin-auth-stat">
            <span class="ft-admin-auth-stat-value">Secure</span>
            <span class="ft-admin-auth-stat-label">Connexion protegee</span>
          </div>
        </div>
      </div>
    </section>

    <section class="ft-admin-auth-panel">
      <div class="ft-admin-auth-card">
        <div class="ft-admin-auth-actions-top">
          <a href="{{ path('app') }}" class="ft-admin-auth-back">
            <i class="bi bi-arrow-left"></i>
            Retour au site
          </a>
          <a href="{{ path('app') }}" class="btn ft-admin-auth-home-btn">
            <i class="bi bi-house-door me-2"></i>Accueil
          </a>
        </div>

        <div class="ft-admin-auth-brand">
          <div class="ft-admin-auth-brand-icon">
            <svg viewBox="0 0 40 40" fill="none" width="34" height="34">
              <rect width="40" height="40" rx="10" fill="#1560BD"/>
              <path d="M10 28V18l10-8 10 8v10H24v-6h-8v6H10Z" fill="white"/>
            </svg>
          </div>
          <div>
            <div class="ft-admin-auth-brand-name">FinTrust</div>
            <div class="ft-admin-auth-brand-sub">Administration</div>
          </div>
        </div>

        <div class="ft-admin-auth-header">
          <h2>Connexion admin</h2>
          <p>Connectez-vous avec votre compte administrateur pour acceder au back-office.</p>
        </div>

        {% if error %}
          <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
            <i class="bi bi-exclamation-octagon-fill me-2"></i>
            <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
          </div>
        {% endif %}

        <form method="post" action="{{ path('admin_login') }}" class="ft-admin-auth-form" novalidate="novalidate">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}"/>
          <input type="hidden" name="_admin_login" value="1"/>

          <div class="mb-3">
            <label for="email" class="form-label">Adresse e-mail admin</label>
            <div class="ft-admin-auth-input">
              <i class="bi bi-envelope"></i>
              <input
                type="email"
                id="email"
                name="email"
                value="{{ last_username }}"
                class="form-control"
                placeholder="admin@fintrust.tn"
                autocomplete="email"
              />
            </div>
          </div>

          <div class="mb-3">
            <label for="password" class="form-label">Mot de passe</label>
            <div class="ft-admin-auth-input">
              <i class="bi bi-lock"></i>
              <input
                type="password"
                id="password"
                name="password"
                class="form-control"
                placeholder="Votre mot de passe"
                autocomplete="current-password"
              />
            </div>
          </div>

          {% if captcha_required %}
            <div class="mb-4">
              <label class="form-label">Verification anti-bot</label>
              <div class="ft-admin-auth-captcha">
                <input type="hidden" name="captcha_token" value="{{ captcha.token }}"/>
                <label class="ft-admin-auth-captcha-check" for="captcha_confirm">
                  <input type="checkbox" id="captcha_confirm" name="captcha_confirm" value="1"/>
                  <span class="ft-admin-auth-captcha-box"><i class="bi bi-check-lg"></i></span>
                  <span class="ft-admin-auth-captcha-label">{{ captcha.label }}</span>
                </label>
                <div class="form-text mt-2">Le CAPTCHA s'active automatiquement apres plusieurs echecs de connexion.</div>
              </div>
            </div>
          {% endif %}

          <div class="d-flex align-items-center justify-content-end mb-4">
            <span class="ft-admin-auth-tag">Back-office securise</span>
          </div>

          <button type="submit" class="btn ft-admin-auth-submit w-100">
            <i class="bi bi-box-arrow-in-right me-2"></i>Acceder a l'administration
          </button>
        </form>
      </div>
    </section>
  </div>
</body>
</html>
