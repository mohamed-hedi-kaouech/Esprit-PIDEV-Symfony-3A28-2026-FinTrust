<div class="publication-form-container">
    <div class="form-header">
        <a href="{{ path('admin_publications_index') }}" class="btn-back">← Retour</a>
        <h1>
            {% if publication.id %}
                ✏️ Modifier la publication
            {% else %}
                ➕ Créer une nouvelle publication
            {% endif %}
        </h1>
    </div>

    {{ form_start(form, {'attr': {'class': 'publication-form', 'novalidate': true}}) }}

    <div class="form-sections">
        <!-- Informations principales -->
        <div class="form-section">
            <h2 class="section-title">📝 Informations principales</h2>
            
            <div class="form-group">
                {{ form_label(form.titre, 'Titre') }}
                {{ form_widget(form.titre, {'attr': {'class': 'form-input', 'placeholder': 'Titre de la publication'}}) }}
                {{ form_errors(form.titre) }}
            </div>

            <div class="form-group">
                {{ form_label(form.contenu, 'Contenu détaillé') }}
                {{ form_widget(form.contenu, {'attr': {'class': 'form-textarea', 'rows': '12', 'placeholder': 'Contenu complet de la publication'}}) }}
                {{ form_errors(form.contenu) }}
            </div>
        </div>

        <!-- Catégorie et statut -->
        <div class="form-section">
            <h2 class="section-title">🏷️ Classification</h2>

            <div class="form-group">
                {{ form_label(form.categorie, 'Catégorie / Thème') }}
                {{ form_widget(form.categorie, {'attr': {'class': 'form-input', 'placeholder': 'Catégorie de la publication'}}) }}
                {{ form_errors(form.categorie) }}
            </div>

            <div class="form-group">
                {{ form_label(form.statut, 'Statut') }}
                {{ form_widget(form.statut, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.statut) }}
                <small class="form-help">Brouillon = invisible, Publié = visible</small>
            </div>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary btn-lg">
            {% if publication.id %}
                ✅ Mettre à jour
            {% else %}
                ✅ Créer la publication
            {% endif %}
        </button>
        <a href="{{ path('admin_publications_index') }}" class="btn btn-secondary btn-lg">Annuler</a>
    </div>

    {{ form_end(form) }}
</div>

<style>
