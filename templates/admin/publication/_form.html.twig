<div class="publication-editor-shell">
    <div class="publication-editor-glow publication-editor-glow--left"></div>
    <div class="publication-editor-glow publication-editor-glow--right"></div>

    <div class="publication-editor-header">
        <a href="{{ path('admin_publications_index') }}" class="publication-editor-back">
            <span class="publication-editor-back__icon">&larr;</span>
            <span>Retour aux publications</span>
        </a>

        <div class="publication-editor-hero">
            <div class="publication-editor-hero__icon">
                <span>&#9998;</span>
            </div>

            <div class="publication-editor-hero__content">
                <span class="publication-editor-hero__chip">
                    {{ publication.id ? 'Edition premium' : 'Nouvelle publication' }}
                </span>
                <h1 class="publication-editor-title">
                    {% if publication.id %}
                        Modifier une publication
                    {% else %}
                        Creer une nouvelle publication
                    {% endif %}
                </h1>
                <p class="publication-editor-subtitle">
                    Affinez votre contenu financier, structurez sa classification et gardez une presentation
                    claire, professionnelle et coherente avec l univers premium FinTrust.
                </p>
            </div>
        </div>
    </div>

    {{ form_start(form, {'attr': {'class': 'publication-editor-form', 'novalidate': 'novalidate'}}) }}

    <div class="publication-editor-card">
        <div class="publication-editor-grid">
            <section class="publication-editor-panel publication-editor-panel--main">
                <div class="publication-editor-panel__header">
                    <span class="publication-editor-panel__icon">&#128221;</span>
                    <div>
                        <h2>Informations principales</h2>
                        <p>Travaillez le titre et le contenu avec un confort d edition plus premium.</p>
                    </div>
                </div>

                <div class="publication-editor-field">
                    {{ form_label(form.titre, 'Titre de la publication', {'label_attr': {'class': 'publication-editor-label'}}) }}
                    <div class="publication-editor-input-wrap">
                        <span class="publication-editor-input-icon">&#10022;</span>
                        {{ form_widget(form.titre, {'attr': {'class': 'publication-editor-input', 'placeholder': 'Ex. Tendances d investissement 2026'}}) }}
                    </div>
                    {{ form_errors(form.titre) }}
                    <small class="publication-editor-help">Choisissez un titre clair, credible et oriente valeur pour vos lecteurs.</small>
                </div>

                <div class="publication-editor-field">
                    {{ form_label(form.contenu, 'Contenu detaille', {'label_attr': {'class': 'publication-editor-label'}}) }}
                    <div class="publication-editor-textarea-wrap">
                        {{ form_widget(form.contenu, {'attr': {'class': 'publication-editor-textarea', 'rows': '14', 'placeholder': 'Developpez ici l analyse, les conseils et les informations utiles pour vos clients FinTrust...'}}) }}
                    </div>
                    {{ form_errors(form.contenu) }}
                    <small class="publication-editor-help">Structurez vos idees avec un ton clair et une information de confiance.</small>
                </div>
            </section>

            <aside class="publication-editor-panel publication-editor-panel--side">
                <div class="publication-editor-panel__header">
                    <span class="publication-editor-panel__icon">&#127991;</span>
                    <div>
                        <h2>Classification</h2>
                        <p>Classez la publication dans le bon univers metier et choisissez sa visibilite.</p>
                    </div>
                </div>

                <div class="publication-editor-field">
                    {{ form_label(form.categorie, 'Categorie / Theme', {'label_attr': {'class': 'publication-editor-label'}}) }}
                    <div class="publication-editor-select-wrap">
                        {{ form_widget(form.categorie, {'attr': {'class': 'publication-editor-select'}}) }}
                    </div>
                    {{ form_errors(form.categorie) }}
                    <small class="publication-editor-help">Finance, assurance, tech, fintech, epargne, investissement, credit, cybersecurite, conformite ou reglementation.</small>
                </div>

                <div class="publication-editor-field">
                    {{ form_label(form.statut, 'Statut editorial', {'label_attr': {'class': 'publication-editor-label'}}) }}
                    <div class="publication-editor-select-wrap">
                        {{ form_widget(form.statut, {'attr': {'class': 'publication-editor-select'}}) }}
                    </div>
                    {{ form_errors(form.statut) }}
                    <small class="publication-editor-help">Brouillon garde la publication invisible. Publie la rend visible pour les clients.</small>
                </div>

                <div class="publication-editor-preview">
                    <span class="publication-editor-preview__eyebrow">Apercu rapide</span>
                    <div class="publication-editor-preview__metric">
                        <span class="publication-editor-preview__label">Categorie</span>
                        <strong>{{ publication.categorie ?: 'A definir' }}</strong>
                    </div>
                    <div class="publication-editor-preview__metric">
                        <span class="publication-editor-preview__label">Statut</span>
                        <strong>{{ publication.statut ?: 'Brouillon' }}</strong>
                    </div>
                    <div class="publication-editor-preview__metric">
                        <span class="publication-editor-preview__label">Mode</span>
                        <strong>{{ publication.id ? 'Mise a jour' : 'Creation' }}</strong>
                    </div>
                </div>
            </aside>
        </div>

        <div class="publication-editor-actions">
            <button type="submit" class="publication-editor-btn publication-editor-btn--primary">
                <span>&#10003;</span>
                <span>
                    {% if publication.id %}
                        Mettre a jour la publication
                    {% else %}
                        Creer la publication
                    {% endif %}
                </span>
            </button>
            <a href="{{ path('admin_publications_index') }}" class="publication-editor-btn publication-editor-btn--ghost">
                <span>&#10005;</span>
                <span>Annuler</span>
            </a>
        </div>
    </div>

    {{ form_end(form) }}
</div>

