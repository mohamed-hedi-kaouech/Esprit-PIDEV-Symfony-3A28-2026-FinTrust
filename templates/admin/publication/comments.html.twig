{% extends 'admin/back.html.twig' %}

{% block title %}Commentaires - {{ publication.titre }}{% endblock %}

{% block admin_content %}
<div class="publication-feedback-page">
    <section class="feedback-hero">
        <div class="feedback-hero__content">
            <a href="{{ path('admin_publications_index') }}" class="feedback-back-link">
                <span class="feedback-back-link__icon">&larr;</span>
                <span>Retour a la liste</span>
            </a>

            <div class="feedback-hero__badge-row">
                <span class="feedback-hero__icon-wrap">
                    <span class="feedback-hero__icon">&#128172;</span>
                </span>
                <span class="feedback-hero__chip">Publication : {{ publication.titre }}</span>
            </div>

            <h1 class="feedback-hero__title">Commentaires et feedbacks</h1>
            <p class="feedback-hero__subtitle">
                Suivez les retours des lecteurs, consultez les commentaires et mesurez l'engagement
                autour de cette publication dans une interface admin plus claire et premium.
            </p>
        </div>

        <div class="feedback-hero__side-card">
            <span class="feedback-hero__side-label">Vue admin</span>
            <strong class="feedback-hero__side-value">{{ commentCount }}</strong>
            <span class="feedback-hero__side-text">
                commentaire{{ commentCount > 1 ? 's' : '' }} visible{{ commentCount > 1 ? 's' : '' }}
            </span>
        </div>
    </section>

    <section class="feedback-stats-grid">
        <article class="feedback-stat-card feedback-stat-card--comments">
            <div class="feedback-stat-card__top">
                <span class="feedback-stat-card__icon">&#128172;</span>
                <span class="feedback-stat-card__label">Commentaires</span>
            </div>
            <strong class="feedback-stat-card__value">{{ commentCount }}</strong>
            <p class="feedback-stat-card__hint">Messages laisses par les utilisateurs.</p>
        </article>

        <article class="feedback-stat-card feedback-stat-card--likes">
            <div class="feedback-stat-card__top">
                <span class="feedback-stat-card__icon">&#128077;</span>
                <span class="feedback-stat-card__label">Likes</span>
            </div>
            <strong class="feedback-stat-card__value">{{ likeCount }}</strong>
            <p class="feedback-stat-card__hint">Retours positifs sur la publication.</p>
        </article>

        <article class="feedback-stat-card feedback-stat-card--dislikes">
            <div class="feedback-stat-card__top">
                <span class="feedback-stat-card__icon">&#128078;</span>
                <span class="feedback-stat-card__label">Dislikes</span>
            </div>
            <strong class="feedback-stat-card__value">{{ dislikeCount }}</strong>
            <p class="feedback-stat-card__hint">Retours negatifs ou reserves detectees.</p>
        </article>

        <article class="feedback-stat-card feedback-stat-card--rating">
            <div class="feedback-stat-card__top">
                <span class="feedback-stat-card__icon">&#9733;</span>
                <span class="feedback-stat-card__label">Engagement</span>
            </div>
            <strong class="feedback-stat-card__value">{{ commentCount + likeCount + dislikeCount }}</strong>
            <p class="feedback-stat-card__hint">Signaux cumules autour de la publication.</p>
        </article>
    </section>

    {% if feedbacks|length > 0 %}
        <section class="feedback-comments-shell">
            <div class="feedback-comments-shell__header">
                <div>
                    <h2 class="feedback-comments-shell__title">Flux des commentaires</h2>
                    <p class="feedback-comments-shell__subtitle">
                        Chaque carte ci-dessous correspond a un commentaire texte laisse par un utilisateur.
                    </p>
                </div>
                <span class="feedback-comments-shell__badge">{{ feedbacks|length }} entree{{ feedbacks|length > 1 ? 's' : '' }}</span>
            </div>

            <div class="comments-list">
                {% for feedback in feedbacks %}
                    <article class="comment-card">
                        <div class="comment-header">
                            <div class="comment-author">
                                <div class="author-avatar">{{ feedback.user.prenom|default('')|first }}{{ feedback.user.nom|default('')|first }}</div>
                                <div class="author-info">
                                    <strong>{{ feedback.user.fullName|default((feedback.user.prenom|default('Utilisateur')) ~ ' ' ~ (feedback.user.nom|default(''))) }}</strong>
                                    <small>{{ feedback.dateFeedback ? feedback.dateFeedback|date('d/m/Y H:i') : 'Date indisponible' }}</small>
                                </div>
                            </div>
                            <span class="comment-status approved">Commentaire client</span>
                        </div>

                        <div class="comment-content">
                            {{ feedback.commentaire }}
                        </div>

                        <div class="comment-meta-pills">
                            {% if feedback.typeReaction %}
                                <span class="comment-meta-pill">
                                    Reaction : {{ feedback.typeReaction|upper == 'LIKE' ? 'Like' : (feedback.typeReaction|upper == 'DISLIKE' ? 'Dislike' : feedback.typeReaction) }}
                                </span>
                            {% endif %}
                            <span class="comment-meta-pill">Publication #{{ publication.id }}</span>
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>
    {% else %}
        <section class="feedback-empty-shell">
            <div class="feedback-empty-card">
                <div class="feedback-empty-card__glow"></div>
                <div class="feedback-empty-card__icon">&#128173;</div>
                <h3 class="feedback-empty-card__title">Aucun commentaire pour le moment</h3>
                <p class="feedback-empty-card__text">
                    Les retours des utilisateurs apparaitront ici des que cette publication commencera
                    a generer de l'engagement.
                </p>
                <div class="feedback-empty-card__actions">
                    <a href="{{ path('admin_publications_index') }}" class="feedback-empty-card__button">
                        Explorer les publications
                    </a>
                </div>
            </div>
        </section>
    {% endif %}
</div>

<style>
.publication-feedback-page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 2rem 2.5rem;
    animation: feedbackFadeIn 0.45s ease;
}

.feedback-hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 1.5rem;
    padding: 2rem;
    border-radius: 30px;
    background:
        radial-gradient(circle at top right, rgba(96, 165, 250, 0.22), transparent 34%),
        linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(239, 246, 255, 0.88) 55%, rgba(237, 233, 254, 0.68));
    border: 1px solid rgba(191, 219, 254, 0.8);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
    overflow: hidden;
}

.feedback-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, rgba(59, 130, 246, 0.06), transparent 30%, rgba(147, 197, 253, 0.08));
    pointer-events: none;
}

.feedback-hero__content,
.feedback-hero__side-card {
    position: relative;
    z-index: 1;
}

.feedback-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.8rem 1.1rem;
    border-radius: 999px;
    color: #1d4ed8;
    text-decoration: none;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(147, 197, 253, 0.55);
    box-shadow: 0 10px 28px rgba(59, 130, 246, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
}

.feedback-back-link:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 16px 32px rgba(37, 99, 235, 0.14);
}

.feedback-back-link__icon {
    width: 1.8rem;
    height: 1.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(219, 234, 254, 0.95);
}

.feedback-hero__badge-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.55rem;
    margin-bottom: 1rem;
}

.feedback-hero__icon-wrap {
    width: 4rem;
    height: 4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 22px;
    background: linear-gradient(135deg, rgba(30, 58, 138, 0.95), rgba(59, 130, 246, 0.92));
    box-shadow: 0 16px 36px rgba(37, 99, 235, 0.22);
}

.feedback-hero__icon {
    font-size: 1.7rem;
}

.feedback-hero__chip {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(191, 219, 254, 0.8);
    color: #334155;
    font-weight: 700;
}

.feedback-hero__title {
    margin: 0;
    font-size: clamp(2.1rem, 4vw, 3.35rem);
    line-height: 1.05;
    color: #0f172a;
}

.feedback-hero__subtitle {
    max-width: 720px;
    margin: 1rem 0 0;
    color: #475569;
    font-size: 1.02rem;
    line-height: 1.8;
}

.feedback-hero__side-card {
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.3rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(191, 219, 254, 0.8);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
}

.feedback-hero__side-label {
    color: #64748b;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
}

.feedback-hero__side-value {
    margin-top: 0.5rem;
    color: #0f172a;
    font-size: 2.8rem;
    line-height: 1;
}

.feedback-hero__side-text {
    margin-top: 0.65rem;
    color: #475569;
    line-height: 1.55;
}

.feedback-stats-grid {
    margin-top: 1.7rem;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
}

.feedback-stat-card {
    padding: 1.25rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.05);
}

.feedback-stat-card__top {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1rem;
}

.feedback-stat-card__icon {
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    background: rgba(219, 234, 254, 0.8);
    font-size: 1.3rem;
}

.feedback-stat-card__label {
    color: #334155;
    font-size: 0.98rem;
    font-weight: 700;
}

.feedback-stat-card__value {
    display: block;
    color: #0f172a;
    font-size: 2.3rem;
    line-height: 1;
}

.feedback-stat-card__hint {
    margin: 0.75rem 0 0;
    color: #64748b;
    font-size: 0.92rem;
    line-height: 1.65;
}

.feedback-comments-shell,
.feedback-empty-shell {
    margin-top: 1.8rem;
}

.feedback-comments-shell {
    padding: 1.4rem;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 22px 50px rgba(15, 23, 42, 0.06);
}

.feedback-comments-shell__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.15rem;
}

.feedback-comments-shell__title {
    margin: 0;
    color: #0f172a;
    font-size: 1.35rem;
}

.feedback-comments-shell__subtitle {
    margin: 0.35rem 0 0;
    color: #64748b;
    line-height: 1.7;
}

.feedback-comments-shell__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    color: #1d4ed8;
    font-weight: 800;
}

.comments-list {
    display: grid;
    gap: 1rem;
}

.comment-card {
    padding: 1.25rem;
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.96));
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 14px 36px rgba(15, 23, 42, 0.04);
}

.comment-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1rem;
}

.comment-author {
    display: flex;
    align-items: center;
    gap: 0.9rem;
}

.author-avatar {
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: linear-gradient(135deg, #1d4ed8, #60a5fa);
    color: #fff;
    font-weight: 800;
}

.author-info strong {
    display: block;
    color: #0f172a;
}

.author-info small {
    color: #64748b;
}

.comment-status {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: #dcfce7;
    color: #166534;
    font-size: 0.82rem;
    font-weight: 800;
}

.comment-content {
    color: #334155;
    line-height: 1.75;
    font-size: 1rem;
}

.comment-meta-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1rem;
}

.comment-meta-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(219, 234, 254, 0.7);
    border: 1px solid rgba(147, 197, 253, 0.55);
    color: #1e3a8a;
    font-size: 0.82rem;
    font-weight: 700;
}

.feedback-empty-card {
    position: relative;
    overflow: hidden;
    padding: 2.4rem 1.8rem;
    border-radius: 30px;
    text-align: center;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(239, 246, 255, 0.96));
    border: 1px solid rgba(191, 219, 254, 0.95);
    box-shadow: 0 22px 50px rgba(15, 23, 42, 0.06);
}

.feedback-empty-card__glow {
    position: absolute;
    inset: auto auto -60px -60px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(96, 165, 250, 0.22), transparent 70%);
}

.feedback-empty-card__icon {
    position: relative;
    z-index: 1;
    width: 5rem;
    height: 5rem;
    margin: 0 auto 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 24px;
    background: linear-gradient(135deg, #1d4ed8, #60a5fa);
    color: #fff;
    font-size: 2rem;
    box-shadow: 0 18px 36px rgba(59, 130, 246, 0.2);
}

.feedback-empty-card__title {
    position: relative;
    z-index: 1;
    margin: 0;
    color: #0f172a;
    font-size: 2rem;
}

.feedback-empty-card__text {
    position: relative;
    z-index: 1;
    max-width: 650px;
    margin: 1rem auto 0;
    color: #64748b;
    line-height: 1.8;
}

.feedback-empty-card__actions {
    position: relative;
    z-index: 1;
    margin-top: 1.5rem;
}

.feedback-empty-card__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.4rem;
    border-radius: 999px;
    text-decoration: none;
    background: linear-gradient(135deg, #1d4ed8, #3b82f6);
    color: #fff;
    font-weight: 800;
    box-shadow: 0 14px 32px rgba(37, 99, 235, 0.2);
}

@keyframes feedbackFadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@media (max-width: 992px) {
    .feedback-hero,
    .feedback-stats-grid {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}
