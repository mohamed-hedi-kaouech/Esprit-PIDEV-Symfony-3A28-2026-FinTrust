{% extends 'admin/back.html.twig' %}

{% block title %}Gestion des Publications{% endblock %}

{% block admin_content %}
<div class="admin-publications-container">
    <!-- En-t├¬te avec bouton d'ajout -->
    <div class="publications-header">
        <div class="header-info">
            <h1 class="page-title">
                <svg class="icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 19.5h16a2.5 2.5 0 0 0 2.5-2.5V6.5H1.5v10.5a2.5 2.5 0 0 0 2.5 2.5z"/>
                    <path d="M1.5 6.5h21M9 11h6M9 15h6"/>
                </svg>
                Publications Bancaires
            </h1>
            <p class="header-subtitle">G├®rez vos publications, offres et contenu financier</p>
        </div>
        <div class="publication-actions">
            <a href="{{ path('admin_publications_create') }}" class="btn btn-primary btn-lg">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 5v14M5 12h14"/>
                </svg>
                Nouvelle Publication
            </a>
            <div class="export-buttons">
                <a href="{{ path('admin_publications_export_csv', {search: search, category: current_category, sort: sort_by}) }}" class="btn btn-secondary btn-lg">Export CSV</a>
                <a href="{{ path('admin_publications_export_pdf', {search: search, category: current_category, sort: sort_by}) }}" class="btn btn-secondary btn-lg">Export PDF</a>
            </div>
        </div>
    </div>

    <!-- Statistiques ├®l├®gantes -->
    <div class="stats-grid">
        <div class="stat-card stat-card-primary">
            <div class="stat-icon">­¤ō░</div>
            <div class="stat-content">
                <h3 class="stat-value">{{ stats.total_publications }}</h3>
                <p class="stat-label">Publications totales</p>
            </div>
        </div>
        <div class="stat-card stat-card-success">
            <div class="stat-icon">Ō£ģ</div>
            <div class="stat-content">
                <h3 class="stat-value">{{ stats.published_publications }}</h3>
                <p class="stat-label">Publications publi├®es</p>
            </div>
        </div>
        <div class="stat-card stat-card-info">
            <div class="stat-icon">­¤Æ¼</div>
            <div class="stat-content">
                <h3 class="stat-value">{{ stats.total_comments }}</h3>
                <p class="stat-label">Commentaires totaux</p>
            </div>
        </div>
        <div class="stat-card stat-card-warning">
            <div class="stat-icon">ŌŁÉ</div>
            <div class="stat-content">
                <h3 class="stat-value">{{ stats.total_feedbacks }}</h3>
                <p class="stat-label">Interactions totales</p>
            </div>
        </div>
    </div>

    <!-- Filtres et recherche -->
    <div class="filters-section">
        <form method="GET" class="filters-form">
            <div class="filter-group">
                <label for="search" class="filter-label">­¤öŹ Rechercher</label>
                <input 
                    type="text" 
                    id="search" 
                    name="search" 
                    value="{{ search }}" 
                    placeholder="Titre ou extrait..."
                    class="filter-input"
                >
            </div>

            <div class="filter-group">
                <label for="category" class="filter-label">­¤ōé Cat├®gorie</label>
                <select id="category" name="category" class="filter-select">
                    <option value="">Toutes les cat├®gories</option>
                    {% for cat in categories %}
                        <option value="{{ cat }}" {% if current_category == cat %}selected{% endif %}>
                            {{ cat starts with 'Actualit' ? 'Actualit&eacute;' : (cat == 'CYBERSECURITE' ? 'Cybers&eacute;curit&eacute;' : (cat == 'TECH' ? 'Tech' : (cat == 'assurance' ? 'Assurance' : cat))) }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="filter-group">
                <label for="sort" class="filter-label">­¤ōŖ Tri</label>
                <select id="sort" name="sort" class="filter-select">
                    <option value="newest" {% if sort_by == 'newest' %}selected{% endif %}>Plus r├®centes</option>
                    <option value="views" {% if sort_by == 'views' %}selected{% endif %}>Plus consult├®es</option>
                    <option value="comments" {% if sort_by == 'comments' %}selected{% endif %}>Plus comment├®es</option>
                    <option value="likes" {% if sort_by == 'likes' %}selected{% endif %}>Tendance</option>
                </select>
            </div>

            <button type="submit" class="btn btn-secondary">Filtrer</button>
        </form>
    </div>

    <!-- Tableau des publications -->
    <div class="publications-table-wrapper">
        {% if publications|length > 0 %}
            <table class="publications-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Cat├®gorie</th>
                        <th>Statut</th>
                        <th>Date</th>
                        <th class="text-center">Vues</th>
                        <th class="text-center">Likes</th>
                        <th class="text-center">Dislikes</th>
                        <th class="text-center">Commentaires</th>
                        <th class="text-center">Note</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for pub in publications %}
                        <tr class="publication-row">
                            <td class="title-cell">
                                <strong>{{ pub.titre|slice(0, 30) }}{{ pub.titre|length > 30 ? '...' : '' }}</strong>
                            </td>
                            <td>
                                <span class="badge badge-category">
                                    {{ pub.categorie ? (pub.categorie starts with 'Actualit' ? 'Actualit&eacute;' : (pub.categorie == 'CYBERSECURITE' ? 'Cybers&eacute;curit&eacute;' : (pub.categorie == 'TECH' ? 'Tech' : (pub.categorie == 'assurance' ? 'Assurance' : pub.categorie)))) : 'Non d&eacute;finie' }}
                                </span>
                            </td>
                            <td>
                                <span class="badge badge-{{ pub.statut == 'PUBLIE' ? 'published' : 'draft' }}">
                                    {% if pub.statut == 'PUBLIE' %}Publie
                                    {% elseif pub.statut == 'BROUILLON' %}Brouillon
                                    {% else %}{{ pub.statut }}{% endif %}
                                </span>
                            </td>
                            <td class="text-muted">{{ pub.datePublication ? pub.datePublication|date('d/m/Y') : 'ŌĆö' }}</td>
                            <td class="text-center">
                                <span class="stat-badge">ŌĆö</span>
                            </td>
                            <td class="text-center">
                                <span class="stat-badge stat-badge-success">ŌĆö</span>
                            </td>
                            <td class="text-center">
                                <span class="stat-badge stat-badge-danger">ŌĆö</span>
                            </td>
                            <td class="text-center">
                                <a href="{{ path('admin_publications_comments', {id: pub.id}) }}" class="stat-badge stat-badge-info stat-badge-link" title="Voir les commentaires">
                                    Commentaires {{ pub.feedbacks|filter(feedback => feedback.commentaire is not empty)|length }}
                                </a>
                            </td>
                            <td class="text-center">
                                <small class="text-muted">Aucune note</small>
                            </td>
                            <td class="text-right">
                                <div class="action-buttons">
                                    <a href="{{ path('admin_publications_comments', {id: pub.id}) }}" class="btn-icon btn-info" title="Commentaires">
                                        ­¤Æ¼
                                    </a>
                                    <a href="{{ path('admin_publications_edit', {id: pub.id}) }}" class="btn-icon btn-warning" title="Modifier">
                                        Ō£Å’ĖÅ
                                    </a>
                                    <form method="POST" action="{{ path('admin_publications_delete', {id: pub.id}) }}" style="display:inline;" onsubmit="return confirm('Confirmer la suppression?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ pub.id) }}">
                                        <button type="submit" class="btn-icon btn-danger" title="Supprimer">­¤Śæ’ĖÅ</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="empty-state">
                <div class="empty-icon">­¤ōŁ</div>
                <h3>Aucune publication trouv├®e</h3>
                <p>Cr├®ez votre premi├©re publication pour commencer</p>
                <a href="{{ path('admin_publications_create') }}" class="btn btn-primary">Cr├®er une publication</a>
            </div>
        {% endif %}
    </div>

    <!-- Pagination -->
    {% if total_pages > 1 %}
        <div class="pagination">
            {% if current_page > 1 %}
                <a href="{{ path('admin_publications_index', {page: 1, search: search, category: current_category, sort: sort_by}) }}" class="page-link">┬½ Premi├©re</a>
                <a href="{{ path('admin_publications_index', {page: current_page - 1, search: search, category: current_category, sort: sort_by}) }}" class="page-link">ŌĆ╣ Pr├®c├®dente</a>
            {% endif %}

            {% for page in range(1, total_pages) %}
                <a 
                    href="{{ path('admin_publications_index', {page: page, search: search, category: current_category, sort: sort_by}) }}" 
                    class="page-link {% if page == current_page %}active{% endif %}"
                >
                    {{ page }}
                </a>
            {% endfor %}

            {% if current_page < total_pages %}
                <a href="{{ path('admin_publications_index', {page: current_page + 1, search: search, category: current_category, sort: sort_by}) }}" class="page-link">Suivante ŌĆ║</a>
                <a href="{{ path('admin_publications_index', {page: total_pages, search: search, category: current_category, sort: sort_by}) }}" class="page-link">Derni├©re ┬╗</a>
            {% endif %}
        </div>
    {% endif %}

    <div class="publication-analytics publication-analytics--advanced">
        <div class="analytics-header">
            <div>
                <h2>Statistiques avancees</h2>
                <p class="analytics-subtitle">
                    Deux analyses plus pratiques : repartition editoriale par categorie et lecture claire du feedback.
                </p>
            </div>
            <span class="analytics-chip">Publication + Feedback</span>
        </div>

        <div class="analytics-summary-grid">
            <div class="analytics-summary-card">
                <span class="analytics-summary-card__label">Commentaires</span>
                <strong class="analytics-summary-card__value">{{ feedback_insights.totals.comments }}</strong>
            </div>
            <div class="analytics-summary-card analytics-summary-card--success">
                <span class="analytics-summary-card__label">Likes</span>
                <strong class="analytics-summary-card__value">{{ feedback_insights.totals.likes }}</strong>
            </div>
            <div class="analytics-summary-card analytics-summary-card--danger">
                <span class="analytics-summary-card__label">Dislikes</span>
                <strong class="analytics-summary-card__value">{{ feedback_insights.totals.dislikes }}</strong>
            </div>
            <div class="analytics-summary-card analytics-summary-card--accent">
                <span class="analytics-summary-card__label">Signals</span>
                <strong class="analytics-summary-card__value">{{ feedback_insights.total_signals }}</strong>
            </div>
        </div>

        <div class="advanced-analytics-grid">
            <section class="advanced-panel">
                <div class="advanced-panel__head">
                    <div>
                        <h3>Chart des publications par categorie</h3>
                        <p>Mesurez le poids editorial et l'engagement de chaque categorie.</p>
                    </div>
                    <span class="advanced-panel__badge">{{ category_performance|length }} categories</span>
                </div>

                <div class="category-performance-list">
                    {% for item in category_performance %}
                        <article class="category-performance-item">
                            <div class="category-performance-item__top">
                                <div>
                                    <h4>{{ item.category starts with 'Actualit' ? 'Actualit&eacute;' : (item.category in ['CYBERSECURITE', 'Cybersecurite', 'Cybers?curit?'] ? 'Cybers&eacute;curit&eacute;' : item.category) }}</h4>
                                    <p>{{ item.publications }} publication{{ item.publications > 1 ? 's' : '' }} Ģ {{ item.engagement }} signal{{ item.engagement > 1 ? 's' : '' }}</p>
                                </div>
                                <div class="category-performance-item__metrics">
                                    <span>&#128077; {{ item.likes }} likes</span>
                                    <span>&#128172; {{ item.comments }} commentaires</span>
                                    <span>&#128078; {{ item.dislikes }} dislikes</span>
                                </div>
                            </div>

                            <div class="performance-bar-group">
                                <div class="performance-bar-row">
                                    <span class="performance-bar-row__label">Part des publications</span>
                                    <span class="performance-bar-row__value">{{ item.publication_ratio }}%</span>
                                </div>
                                <div class="performance-bar-track">
                                    <div class="performance-bar-track__fill" style="width: {{ item.publication_ratio }}%"></div>
                                </div>
                            </div>

                            <div class="performance-bar-group">
                                <div class="performance-bar-row">
                                    <span class="performance-bar-row__label">Intensite feedback</span>
                                    <span class="performance-bar-row__value">{{ item.engagement_ratio }}%</span>
                                </div>
                                <div class="performance-bar-track performance-bar-track--engagement">
                                    <div class="performance-bar-track__fill performance-bar-track__fill--engagement" style="width: {{ item.engagement_ratio }}%"></div>
                                </div>
                            </div>
                        </article>
                    {% else %}
                        <div class="advanced-empty-state">
                            <h4>Aucune categorie exploitable</h4>
                            <p>Les statistiques par categorie apparaitront ici des que les publications seront mieux structurees.</p>
                        </div>
                    {% endfor %}
                </div>
            </section>

            <section class="advanced-panel">
                <div class="advanced-panel__head">
                    <div>
                        <h3>Chart hebdomadaire des publications</h3>
                        <p>Visualisez les jours ou vos publications sont le plus souvent mises en ligne.</p>
                    </div>
                    <span class="advanced-panel__badge">Lundi a Dimanche</span>
                </div>

                <div class="weekly-publication-chart">
                    {% for item in weekly_publication_stats %}
                        <div class="weekly-publication-chart__row">
                            <div class="weekly-publication-chart__label-wrap">
                                <span class="weekly-publication-chart__label">{{ item.label }}</span>
                                <span class="weekly-publication-chart__count">{{ item.count }} publication{{ item.count > 1 ? 's' : '' }}</span>
                            </div>
                            <div class="weekly-publication-chart__track">
                                <div class="weekly-publication-chart__fill" style="width: {{ item.ratio }}%"></div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="feedback-ratio-stack feedback-ratio-stack--compact">
                    <div class="feedback-ratio-card feedback-ratio-card--success">
                        <div class="feedback-ratio-card__top">
                            <span class="feedback-ratio-card__label">Ratio positif</span>
                            <strong class="feedback-ratio-card__value">{{ feedback_insights.positive_rate }}%</strong>
                        </div>
                        <div class="feedback-ratio-card__track">
                            <div class="feedback-ratio-card__fill" style="width: {{ feedback_insights.positive_rate }}%"></div>
                        </div>
                    </div>

                    <div class="feedback-ratio-card feedback-ratio-card--neutral">
                        <div class="feedback-ratio-card__top">
                            <span class="feedback-ratio-card__label">Part commentaires</span>
                            <strong class="feedback-ratio-card__value">{{ feedback_insights.comment_rate }}%</strong>
                        </div>
                        <div class="feedback-ratio-card__track">
                            <div class="feedback-ratio-card__fill" style="width: {{ feedback_insights.comment_rate }}%"></div>
                        </div>
                    </div>

                    <div class="feedback-ratio-card feedback-ratio-card--danger">
                        <div class="feedback-ratio-card__top">
                            <span class="feedback-ratio-card__label">Ratio negatif</span>
                            <strong class="feedback-ratio-card__value">{{ feedback_insights.negative_rate }}%</strong>
                        </div>
                        <div class="feedback-ratio-card__track">
                            <div class="feedback-ratio-card__fill" style="width: {{ feedback_insights.negative_rate }}%"></div>
                        </div>
                    </div>
                </div>

                <div class="feedback-category-table">
                    <div class="feedback-category-table__head">
                        <span>Categorie</span>
                        <span>Signals</span>
                    </div>
                    {% for item in feedback_insights.top_feedback_categories %}
                        <div class="feedback-category-table__row">
                            <div>
                                <strong>{{ item.category starts with 'Actualit' ? 'Actualit&eacute;' : (item.category in ['CYBERSECURITE', 'Cybersecurite', 'Cybers?curit?'] ? 'Cybers&eacute;curit&eacute;' : item.category) }}</strong>
                                <small>&#128172; {{ item.comments }} commentaires &nbsp; &#128077; {{ item.likes }} likes &nbsp; &#128078; {{ item.dislikes }} dislikes</small>
                            </div>
                            <span class="feedback-category-table__total">{{ item.total }}</span>
                        </div>
                    {% else %}
                        <div class="advanced-empty-state">
                            <h4>Aucun feedback exploitable</h4>
                            <p>Les signaux d'engagement apparaitront ici des que les utilisateurs commenceront a interagir.</p>
                        </div>
                    {% endfor %}
                </div>
            </section>
            </section>
        </div></div>
</div>

<style>
.admin-publications-container {
    padding: 2rem;
}

.publications-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
}

.page-title {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
}

.header-subtitle {
    color: #64748b;
    margin: 0.5rem 0 0;
}

.icon-lg { width: 2rem; height: 2rem; }
.icon { width: 1.25rem; height: 1.25rem; }

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.stat-card {
    padding: 1.5rem;
    border-radius: 12px;
    display: flex;
    gap: 1rem;
    align-items: center;
    border: 1px solid #e2e8f0;
}

.stat-card-primary { background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); }
.stat-card-success { background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%); }
.stat-card-info { background: linear-gradient(135deg, #cffafe 0%, #a5f3fc 100%); }
.stat-card-warning { background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); }

.stat-icon {
    font-size: 2.5rem;
}

.stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0;
}

.stat-label {
    font-size: 0.875rem;
    color: #64748b;
    margin: 0;
}

.filters-section {
    background: #fff;
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    margin-bottom: 2rem;
}

.filters-form {
    display: grid;
    grid-template-columns: 1fr minmax(200px, 1fr) minmax(200px, 1fr) auto;
    gap: 1rem;
    align-items: flex-end;
}

.filter-group {
    display: flex;
    flex-direction: column;
}

.filter-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #334155;
    margin-bottom: 0.5rem;
}

.filter-input,
.filter-select {
    padding: 0.625rem 0.875rem;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    font-size: 0.875rem;
}

.publications-table-wrapper {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    overflow: hidden;
}

.publications-table {
    width: 100%;
    border-collapse: collapse;
}

.publications-table thead {
    background: #f8fafc;
    border-bottom: 2px solid #e2e8f0;
}

.publications-table th {
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.875rem;
    color: #475569;
}

.publications-table tbody tr {
    border-bottom: 1px solid #e2e8f0;
    transition: background 0.2s;
}

.publications-table tbody tr:hover {
    background: #f1f5f9;
}

.title-cell {
    font-weight: 500;
}

.pie-chart-card {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1.5rem;
    align-items: center;
}

.pie-chart {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    position: relative;
    box-shadow: inset 0 0 0 16px #f8fafc, 0 20px 40px rgba(15, 23, 42, 0.08);
}

.pie-center {
    position: absolute;
    inset: 50px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #ffffff;
    text-align: center;
    box-shadow: 0 0 0 8px rgba(255, 255, 255, 0.9);
}

.pie-center span {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
}

.pie-center small {
    display: block;
    color: #64748b;
    margin-top: 0.25rem;
}

.pie-legend {
    display: grid;
    gap: 0.75rem;
}

.pie-legend-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: #334155;
}

.legend-color {
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    display: inline-block;
}

.publication-analytics--advanced {
    background:
        radial-gradient(circle at top right, rgba(96, 165, 250, 0.14), transparent 28%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.98));
}

.analytics-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.analytics-subtitle {
    margin: 0.45rem 0 0;
    color: #64748b;
    line-height: 1.65;
}

.analytics-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    color: #1d4ed8;
    font-weight: 700;
    white-space: nowrap;
}

.analytics-summary-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.analytics-summary-card {
    padding: 1.1rem 1.2rem;
    border-radius: 16px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.04);
}

.analytics-summary-card--success {
    background: linear-gradient(180deg, #f0fdf4, #dcfce7);
}

.analytics-summary-card--danger {
    background: linear-gradient(180deg, #fff1f2, #ffe4e6);
}

.analytics-summary-card--accent {
    background: linear-gradient(180deg, #eff6ff, #dbeafe);
}

.analytics-summary-card__label {
    display: block;
    color: #64748b;
    font-size: 0.85rem;
    margin-bottom: 0.45rem;
}

.analytics-summary-card__value {
    color: #0f172a;
    font-size: 2rem;
    line-height: 1;
}

.advanced-analytics-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.95fr;
    gap: 1.25rem;
}

.advanced-panel {
    padding: 1.35rem;
    border-radius: 20px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(239, 246, 255, 0.92));
    border: 1px solid #e2e8f0;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
