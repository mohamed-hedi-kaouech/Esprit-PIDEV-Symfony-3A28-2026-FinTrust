{% extends 'admin/back.html.twig' %}

{% block title %}Gestion des Publications{% endblock %}

{% block admin_content %}
<div class="admin-publications-container">
    <!-- En-tête avec bouton d'ajout -->
    <div class="publications-header">
        <div class="header-info">
            <h1 class="page-title">
                <svg class="icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 19.5h16a2.5 2.5 0 0 0 2.5-2.5V6.5H1.5v10.5a2.5 2.5 0 0 0 2.5 2.5z"/>
                    <path d="M1.5 6.5h21M9 11h6M9 15h6"/>
                </svg>
                Publications Bancaires
            </h1>
            <p class="header-subtitle">Gérez vos publications, offres et contenu financier</p>
        </div>
        <div class="publication-actions">
            <a href="{{ path('admin_publications_create') }}" class="btn btn-primary btn-lg">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 5v14M5 12h14"/>
                </svg>
                Nouvelle Publication
            </a>
            <div class="export-buttons">
                <a href="{{ path('admin_publications_export_csv', {search: search, category: current_category, sort: sort_by}) }}" class="btn btn-secondary btn-lg">Export CSV</a>
                <a href="{{ path('admin_publications_export_pdf', {search: search, category: current_category, sort: sort_by}) }}" class="btn btn-secondary btn-lg">Export PDF</a>
            </div>
        </div>
    </div>

    <!-- Statistiques élégantes -->
    <div class="stats-grid">
        <div class="stat-card stat-card-primary">
            <div class="stat-icon">📰</div>
            <div class="stat-content">
                <h3 class="stat-value">{{ stats.total_publications }}</h3>
                <p class="stat-label">Publications totales</p>
            </div>
        </div>
        <div class="stat-card stat-card-success">
            <div class="stat-icon">✅</div>
            <div class="stat-content">
                <h3 class="stat-value">{{ stats.published_publications }}</h3>
                <p class="stat-label">Publications publiées</p>
            </div>
        </div>
        <div class="stat-card stat-card-info">
            <div class="stat-icon">💬</div>
            <div class="stat-content">
                <h3 class="stat-value">{{ stats.total_comments }}</h3>
                <p class="stat-label">Commentaires totaux</p>
            </div>
        </div>
        <div class="stat-card stat-card-warning">
            <div class="stat-icon">⭐</div>
            <div class="stat-content">
                <h3 class="stat-value">{{ stats.total_feedbacks }}</h3>
                <p class="stat-label">Interactions totales</p>
            </div>
        </div>
    </div>

    <!-- Filtres et recherche -->
    <div class="filters-section">
        <form method="GET" class="filters-form">
            <div class="filter-group">
                <label for="search" class="filter-label">🔍 Rechercher</label>
                <input 
                    type="text" 
                    id="search" 
                    name="search" 
                    value="{{ search }}" 
                    placeholder="Titre ou extrait..."
                    class="filter-input"
                >
            </div>

            <div class="filter-group">
                <label for="category" class="filter-label">📂 Catégorie</label>
                <select id="category" name="category" class="filter-select">
                    <option value="">Toutes les catégories</option>
                    {% for cat in categories %}
                        <option value="{{ cat }}" {% if current_category == cat %}selected{% endif %}>
                            {{ cat }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="filter-group">
                <label for="sort" class="filter-label">📊 Tri</label>
                <select id="sort" name="sort" class="filter-select">
                    <option value="newest" {% if sort_by == 'newest' %}selected{% endif %}>Plus récentes</option>
                    <option value="views" {% if sort_by == 'views' %}selected{% endif %}>Plus consultées</option>
                    <option value="comments" {% if sort_by == 'comments' %}selected{% endif %}>Plus commentées</option>
                    <option value="likes" {% if sort_by == 'likes' %}selected{% endif %}>Tendance</option>
                </select>
            </div>

            <button type="submit" class="btn btn-secondary">Filtrer</button>
        </form>
    </div>

    <!-- Tableau des publications -->
    <div class="publications-table-wrapper">
        {% if publications|length > 0 %}
            <table class="publications-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Catégorie</th>
                        <th>Statut</th>
                        <th>Date</th>
                        <th class="text-center">Vues</th>
                        <th class="text-center">Likes</th>
                        <th class="text-center">Dislikes</th>
                        <th class="text-center">Commentaires</th>
                        <th class="text-center">Note</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for pub in publications %}
                        <tr class="publication-row">
                            <td class="title-cell">
                                <strong>{{ pub.titre|slice(0, 30) }}{{ pub.titre|length > 30 ? '...' : '' }}</strong>
                            </td>
                            <td>
                                <span class="badge badge-category">
                                    {{ pub.categorie ?: 'Non définie' }}
                                </span>
                            </td>
                            <td>
                                <span class="badge badge-{{ pub.statut|lower }}">
                                    {% if pub.statut == 'PUBLIÉ' %}✅ Publié
                                    {% elseif pub.statut == 'BROUILLON' %}📝 Brouillon
                                    {% else %}📦 Archivé{% endif %}
                                </span>
                            </td>
                            <td class="text-muted">{{ pub.datePublication ? pub.datePublication|date('d/m/Y') : '—' }}</td>
                            <td class="text-center">
                                <span class="stat-badge">—</span>
                            </td>
                            <td class="text-center">
                                <span class="stat-badge stat-badge-success">—</span>
                            </td>
                            <td class="text-center">
                                <span class="stat-badge stat-badge-danger">—</span>
                            </td>
                            <td class="text-center">
                                <span class="stat-badge stat-badge-info">
                                    💬 {{ pub.feedbacks|length }}
                                </span>
                            </td>
                            <td class="text-center">
                                <small class="text-muted">Aucune note</small>
                            </td>
                            <td class="text-right">
                                <div class="action-buttons">
                                    <a href="{{ path('admin_publications_comments', {id: pub.id}) }}" class="btn-icon btn-info" title="Commentaires">
                                        💬
                                    </a>
                                    <a href="{{ path('admin_publications_edit', {id: pub.id}) }}" class="btn-icon btn-warning" title="Modifier">
                                        ✏️
                                    </a>
                                    <form method="POST" action="{{ path('admin_publications_delete', {id: pub.id}) }}" style="display:inline;" onsubmit="return confirm('Confirmer la suppression?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ pub.id) }}">
                                        <button type="submit" class="btn-icon btn-danger" title="Supprimer">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <h3>Aucune publication trouvée</h3>
                <p>Créez votre première publication pour commencer</p>
                <a href="{{ path('admin_publications_create') }}" class="btn btn-primary">Créer une publication</a>
            </div>
        {% endif %}
    </div>

    <!-- Pagination -->
    {% if total_pages > 1 %}
        <div class="pagination">
            {% if current_page > 1 %}
                <a href="{{ path('admin_publications_index', {page: 1, search: search, category: current_category, sort: sort_by}) }}" class="page-link">« Première</a>
                <a href="{{ path('admin_publications_index', {page: current_page - 1, search: search, category: current_category, sort: sort_by}) }}" class="page-link">‹ Précédente</a>
            {% endif %}

            {% for page in range(1, total_pages) %}
                <a 
                    href="{{ path('admin_publications_index', {page: page, search: search, category: current_category, sort: sort_by}) }}" 
                    class="page-link {% if page == current_page %}active{% endif %}"
                >
                    {{ page }}
                </a>
            {% endfor %}

            {% if current_page < total_pages %}
                <a href="{{ path('admin_publications_index', {page: current_page + 1, search: search, category: current_category, sort: sort_by}) }}" class="page-link">Suivante ›</a>
                <a href="{{ path('admin_publications_index', {page: total_pages, search: search, category: current_category, sort: sort_by}) }}" class="page-link">Dernière »</a>
            {% endif %}
        </div>
    {% endif %}

    <div class="publication-analytics">
        <h2>Statistiques avancées</h2>

        <div class="analytics-grid">
            <div class="stat-card stat-card-primary">
                <div class="stat-card-icon">💬</div>
                <div>
                    <p class="stat-card-title">Commentaires</p>
                    <p class="stat-card-number">{{ feedback_stats.comments }}</p>
                </div>
            </div>
            <div class="stat-card stat-card-success">
                <div class="stat-card-icon">👍</div>
                <div>
                    <p class="stat-card-title">Likes</p>
                    <p class="stat-card-number">{{ feedback_stats.likes }}</p>
                </div>
            </div>
            <div class="stat-card stat-card-warning">
                <div class="stat-card-icon">👎</div>
                <div>
                    <p class="stat-card-title">Dislikes</p>
                    <p class="stat-card-number">{{ feedback_stats.dislikes }}</p>
                </div>
            </div>
        </div>

        <div class="analytics-grid analytics-grid-3">
            <div class="chart-card">
                <h3>Répartition circulaire</h3>
                {% set totalTrend = 0 %}
                {% for point in publication_trend %}
                    {% set totalTrend = totalTrend + point.count %}
                {% endfor %}

                {% set colorPalette = ["#3b82f6", "#ec4899", "#f97316", "#22c55e", "#8b5cf6", "#14b8a6"] %}
                {% set offset = 0 %}
                {% set gradientStops = [] %}
                {% for point in publication_trend %}
                    {% set percentage = totalTrend > 0 ? (point.count / totalTrend * 100) : 0 %}
                    {% set stop = colorPalette[loop.index0 % colorPalette|length] ~ ' ' ~ offset ~ '% ' ~ (offset + percentage) ~ '%' %}
                    {% set gradientStops = gradientStops|merge([stop]) %}
                    {% set offset = offset + percentage %}
                {% endfor %}

                <div class="pie-chart-card">
                    <div class="pie-chart" style="background: {{ totalTrend > 0 ? 'conic-gradient(' ~ gradientStops|join(', ') ~ ')' : '#e2e8f0' }};">
                        <div class="pie-center">
                            <span>{{ totalTrend }}</span>
                            <small>publications</small>
                        </div>
                    </div>
                    <div class="pie-legend">
                        {% for point in publication_trend %}
                            {% set color = colorPalette[loop.index0 % colorPalette|length] %}
                            <div class="pie-legend-item">
                                <span class="legend-color" style="background: {{ color }}"></span>
                                <span>{{ point.label }} ({{ point.count }})</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="chart-card">
                <h3>Catégories</h3>
                <div class="category-breakdown">
                    <table>
                        <thead>
                            <tr><th>Catégorie</th><th>Publications</th></tr>
                        </thead>
                        <tbody>
                            {% for item in category_stats %}
                                <tr>
                                    <td>{{ item.category ?: 'Non défini' }}</td>
                                    <td>{{ item.count }}</td>
                                </tr>
                            {% else %}
                                <tr><td colspan="2">Aucune catégorie définie</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.admin-publications-container {
    padding: 2rem;
}

.publications-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
}

.page-title {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
}

.header-subtitle {
    color: #64748b;
    margin: 0.5rem 0 0;
}

.icon-lg { width: 2rem; height: 2rem; }
