    }

    .publication-analytics {
        margin-top: 2.5rem;
        padding: 1.5rem;
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .publication-analytics h2 {
        margin-bottom: 1rem;
        color: #0f172a;
        font-size: 1.5rem;
    }

    .analytics-grid {
        display: grid;
