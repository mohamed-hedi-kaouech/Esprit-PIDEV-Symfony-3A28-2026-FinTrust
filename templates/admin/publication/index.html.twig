}

.title-cell {
    font-weight: 500;
}

.pie-chart-card {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1.5rem;
    align-items: center;
}

.pie-chart {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    position: relative;
    box-shadow: inset 0 0 0 16px #f8fafc, 0 20px 40px rgba(15, 23, 42, 0.08);
}

.pie-center {
    position: absolute;
    inset: 50px;
    display: flex;
    flex-direction: column;
    align-items: center;
