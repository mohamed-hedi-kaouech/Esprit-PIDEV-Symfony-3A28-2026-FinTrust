}

@media (max-width: 768px) {
    .publications-header {
        flex-direction: column;
        gap: 1rem;
    }

    .filters-form {
        grid-template-columns: 1fr;
    }

    .publications-table {
        font-size: 0.75rem;
    }

    .action-buttons {
        font-size: 0.75rem;
    }
}
</style>

<script>
  const debounce = (fn, delay = 400) => {
    let timer;
    return (...args) => {
      clearTimeout(timer);
      timer = setTimeout(() => fn(...args), delay);
    };
  };

  const searchInput = document.getElementById('search');
  const categorySelect = document.getElementById('category');
  const sortSelect = document.getElementById('sort');
  const filterForm = document.querySelector('.filters-form');

  if (searchInput && categorySelect && sortSelect && filterForm) {
    searchInput.addEventListener('input', debounce(() => filterForm.submit()));
    categorySelect.addEventListener('change', () => filterForm.submit());
    sortSelect.addEventListener('change', () => filterForm.submit());
  }
</script>
