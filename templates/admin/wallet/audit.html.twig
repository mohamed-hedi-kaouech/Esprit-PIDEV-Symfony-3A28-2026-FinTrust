{% extends 'admin/back.html.twig' %}
{% block title %}Audit wallet{% endblock %}

{% block breadcrumb %}
  <a href="{{ path('admin_dashboard') }}" class="text-muted small text-decoration-none">Dashboard</a>
  <i class="bi bi-chevron-right mx-1 text-muted small"></i>
  <a href="{{ path('admin_wallet_stats') }}" class="text-muted small text-decoration-none">Wallet</a>
  <i class="bi bi-chevron-right mx-1 text-muted small"></i>
  <span class="fw-semibold small">Audit</span>
{% endblock %}

{% block admin_content %}
<section class="ft-admin-card">
  <div class="ft-admin-card-header d-flex justify-content-between align-items-center">
    <span><i class="bi bi-shield-check me-2 text-primary"></i>Journal d audit wallet</span>
    <a href="{{ path('admin_wallet_stats') }}" class="btn ft-btn-outline-primary">Retour stats</a>
  </div>
  <div class="ft-admin-card-body p-0">
    {% if entries is empty %}
      <div class="p-4 text-muted">Aucune entree d audit disponible.</div>
    {% else %}
      <div class="table-responsive">
        <table class="table ft-admin-table align-middle mb-0">
          <thead>
            <tr><th>Date</th><th>Action</th><th>User</th><th>Wallet</th><th>Reference</th><th>Statut</th></tr>
          </thead>
          <tbody>
            {% for entry in entries %}
              <tr>
                <td>{{ entry.timestamp|date('d/m/Y H:i') }}</td>
                <td>{{ entry.action }}</td>
                <td>{{ entry.user_id ?? entry.sender_user_id ?? '-' }}</td>
                <td>{{ entry.wallet_id ?? entry.source_wallet_id ?? '-' }}</td>
                <td>{{ entry.reference ?? '-' }}</td>
                <td>{{ entry.status ?? '-' }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</section>
{% endblock %}
