{% extends 'admin/back.html.twig' %}

{% block title %}Alertes budgetaires{% endblock %}

{% block admin_content %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="h3 mb-0 text-gray-800">Alertes budgetaires</h1>
            <p class="text-muted">Liste des alertes déclenchées lorsque le seuil de la catégorie est atteint.</p>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            {% if alertes is empty %}
                <div class="alert alert-info">
                    Aucune alerte budgetaire n'a été déclenchée pour le moment.
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Catégorie</th>
                                <th>Message</th>
                                <th>Seuil</th>
                                <th>Créée le</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for alerte in alertes %}
                                <tr>
                                    <td>{{ alerte.idAlerte }}</td>
                                    <td>{{ alerte.categorie ? alerte.categorie.nomCategorie : 'N/A' }}</td>
                                    <td>{{ alerte.message }}</td>
                                    <td>{{ alerte.seuil|number_format(2, ',', ' ') }} €</td>
                                    <td>{{ alerte.createdAt|date('d/m/Y H:i') }}</td>
                                    <td>
                                        {% if alerte.active %}
                                            <span class="badge bg-warning text-dark">Active</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Inactif</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}