{#
  ============================================================
  LAYOUT PRINCIPAL — BACK OFFICE (Admin)
  templates/admin/back.html.twig

  Toutes les pages admin héritent de ce layout.
  Design Bootstrap 5 + sidebar sombre FinTrust Admin.
  ============================================================
#}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{% block title %}Administration{% endblock %} — FinTrust Admin</title>

  {# Bootstrap 5 CSS #}
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  {# Bootstrap Icons #}
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  {# Google Fonts #}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  {# CSS Admin FinTrust #}
  <link rel="stylesheet" href="{{ asset('css/fintrust-admin.css') }}"/>
  {# CSS Design Moderne #}
  <link rel="stylesheet" href="{{ asset('css/design-modern.css') }}"/>

  {% block stylesheets %}{% endblock %}
</head>
<body class="ft-admin-body">

  {# ============================================================
     WRAPPER PRINCIPAL (sidebar + contenu)
  ============================================================ #}
  <div class="ft-admin-wrapper">

    {# ============================================================
       SIDEBAR
    ============================================================ #}
    <aside class="ft-sidebar" id="ftSidebar">

      {# Logo / Brand #}
      <div class="ft-sidebar-brand">
        <svg viewBox="0 0 40 40" fill="none" width="32" height="32">
          <rect width="40" height="40" rx="10" fill="#1560BD"/>
          <path d="M10 28V18l10-8 10 8v10H24v-6h-8v6H10Z" fill="white"/>
        </svg>
        <div class="ms-2">
          <div class="ft-sidebar-brand-name">FinTrust</div>
          <div class="ft-sidebar-brand-sub">Administration</div>
        </div>
      </div>

      {# Navigation #}
      <nav class="ft-sidebar-nav mt-3">

        <div class="ft-sidebar-section-label">Principal</div>

        <a href="{{ path('admin_dashboard') }}"
           class="ft-sidebar-link {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}">
          <i class="bi bi-speedometer2"></i>
          <span>Tableau de bord</span>
        </a>

        <div class="ft-sidebar-section-label mt-3">Gestion</div>

        <a href="{{ path('admin_user_list') }}"
           class="ft-sidebar-link {% if 'admin_user_' in app.request.attributes.get('_route') %}active{% endif %}">
          <i class="bi bi-people-fill"></i>
          <span>Utilisateurs</span>
        </a>

        <a href="{{ path('admin_user_create') }}"
           class="ft-sidebar-link {% if app.request.attributes.get('_route') == 'admin_user_create' %}active{% endif %}">
          <i class="bi bi-person-plus-fill"></i>
          <span>Ajouter un client</span>
        </a>

        <a href="{{ path('admin_kyc_list') }}"
           class="ft-sidebar-link {% if 'admin_kyc_' in app.request.attributes.get('_route') %}active{% endif %}">
          <i class="bi bi-shield-check"></i>
          <span>Dossiers KYC</span>
          {# Badge compteur KYC en attente — à passer via Twig global si besoin #}
        </a>

        <a href="{{ path('admin_alerte_list') }}"
           class="ft-sidebar-link {% if 'admin_alerte_' in app.request.attributes.get('_route') %}active{% endif %}">
          <i class="bi bi-bell-fill"></i>
          <span>Alertes budget</span>
          {% set activeAlertsCount = active_alerts_count.getActiveAlertsCount() %}
          {% if activeAlertsCount > 0 %}
            <span class="badge bg-danger ms-auto">{{ activeAlertsCount }}</span>
          {% endif %}
        </a>
        <a href="{{ path('product_list') }}" class="ft-sidebar-link">
          <i class="bi bi-box-seam"></i>
          <span>Catalogue produits</span>
        </a>
        <a href="{{ path('subscription_list') }}" class="ft-sidebar-link">
          <i class="bi bi-box-seam"></i>
          <span>Catalogue Abonnements</span>
        </a>
        <div class="ft-sidebar-section-label mt-3">Services</div>

        <a href="{{ path('admin_wallet_index') }}"
           class="ft-sidebar-link {% if 'admin_wallet_' in app.request.attributes.get('_route') %}active{% endif %}">
        <a href="{{ path('index') }}" class="ft-sidebar-link">
          <i class="bi bi-box-seam"></i>
          <span>Dashboard Produits</span>
        </a>

        <a href="{{ path('admin_dashboard') }}#admin-wallet" class="ft-sidebar-link">
          <i class="bi bi-wallet2"></i>
          <span>Pilotage Wallet</span>
        </a>

        <a href="{{ path('admin_cheque_index') }}"
           class="ft-sidebar-link {% if 'admin_cheque_' in app.request.attributes.get('_route') %}active{% endif %}">
          <i class="bi bi-journal-check"></i>
          <span>Gerer les cheques</span>
        </a>

        <a href="{{ path('admin_loan_dashboard') }}" class="ft-sidebar-link">
          <i class="bi bi-bank"></i>
          <span>Gestion des prets</span>
        </a>

        <a href="{{ path('admin_categorie_list') }}" class="ft-sidebar-link">
          <i class="bi bi-calculator"></i>
          <span>Suivi budgetaire</span>
        </a>

        <a href="{{ path('admin_dashboard') }}#admin-publications" class="ft-sidebar-link">
          <i class="bi bi-newspaper"></i>
          <span>Centre publications</span>
        </a>

      </nav>

      {# Profil admin en bas #}
      <div class="ft-sidebar-footer">
        <div class="ft-sidebar-user">
          <div class="ft-sidebar-avatar">
            {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
          </div>
          <div class="ft-sidebar-user-info">
            <div class="ft-sidebar-user-name">{{ app.user.fullName }}</div>
            <div class="ft-sidebar-user-role">Administrateur</div>
          </div>
        </div>
        <a href="{{ path('app_logout') }}?from=admin" class="ft-sidebar-logout" title="Déconnexion">
          <i class="bi bi-box-arrow-right"></i>
        </a>
      </div>

    </aside>

    {# ============================================================
       CONTENU PRINCIPAL
    ============================================================ #}
    <div class="ft-admin-content">

      {# Topbar #}
      <header class="ft-topbar">
        <button class="btn btn-sm ft-sidebar-toggle me-3" id="sidebarToggle" type="button">
          <i class="bi bi-list fs-5"></i>
        </button>
        <div class="ft-topbar-main">
          <div class="ft-topbar-breadcrumb">
            {% block breadcrumb %}
              <span class="text-muted small">Administration</span>
            {% endblock %}
          </div>
          <div class="ft-topbar-motivation" id="adminMotivation"
               data-messages='[
                 "Chaque action terminee rapproche de l objectif final.",
                 "La rigueur d aujourd hui construit une meilleure plateforme demain.",
                 "Chaque dossier traite renforce la confiance du systeme.",
                 "Une plateforme fiable se construit par des actions precises.",
                 "La constance transforme les objectifs en resultats.",
                 "Chaque validation compte dans la qualite du service.",
                 "Gardez le cap, chaque controle ameliore la conformite.",
                 "Chaque decision admin renforce la stabilite du systeme."
               ]'>
            <span class="ft-topbar-motivation-badge">
              <i class="bi bi-stars"></i>
              Motivation admin
            </span>
            <span class="ft-topbar-motivation-text" id="adminMotivationText">
              Chaque action terminee rapproche de l objectif final.
            </span>
          </div>
        </div>
        <div class="ms-auto d-flex align-items-center gap-3">
          <a href="{{ path('app') }}" class="btn btn-sm ft-btn-outline-primary" target="_blank">
            <i class="bi bi-eye me-1"></i>Voir le site
          </a>
        </div>
      </header>

      {# Flash messages #}
      {% if app.flashes|length > 0 %}
        <div class="px-4 pt-3">
          {% for type, messages in app.flashes %}
            {% set bsType = type == 'error' ? 'danger' : type %}
            {% for message in messages %}
              <div class="alert alert-{{ bsType }} alert-dismissible fade show d-flex align-items-center" role="alert">
                {% if type == 'success' %}<i class="bi bi-check-circle-fill me-2"></i>
                {% elseif type == 'error' %}<i class="bi bi-x-circle-fill me-2"></i>
                {% elseif type == 'warning' %}<i class="bi bi-exclamation-triangle-fill me-2"></i>
                {% else %}<i class="bi bi-info-circle-fill me-2"></i>{% endif %}
                <span>{{ message }}</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
              </div>
            {% endfor %}
          {% endfor %}
        </div>
      {% endif %}

      {# Page content #}
      <div class="ft-admin-page px-4 py-4">
        {% block admin_content %}{% endblock %}
      </div>

    </div>{# /.ft-admin-content #}

  </div>{# /.ft-admin-wrapper #}

  {# Bootstrap 5 JS #}
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  {# Toggle sidebar mobile #}
  <script>
    document.getElementById('sidebarToggle')?.addEventListener('click', function() {
      document.getElementById('ftSidebar').classList.toggle('ft-sidebar-collapsed');
      document.querySelector('.ft-admin-content').classList.toggle('ft-content-expanded');
    });

    const motivationRoot = document.getElementById('adminMotivation');
    const motivationText = document.getElementById('adminMotivationText');
    if (motivationRoot && motivationText) {
      const messages = JSON.parse(motivationRoot.dataset.messages || '[]');
      if (messages.length > 0) {
        let index = Math.floor(Math.random() * messages.length);

        const renderMessage = () => {
          motivationText.classList.remove('is-visible');
          window.setTimeout(() => {
            motivationText.textContent = messages[index];
            motivationText.classList.add('is-visible');
          }, 140);
        };

        renderMessage();

        if (messages.length > 1) {
          window.setInterval(() => {
            index = (index + 1) % messages.length;
            renderMessage();
          }, 9000);
        }
      }
    }
  </script>

  {% block javascripts %}{% endblock %}
</body>
</html>
