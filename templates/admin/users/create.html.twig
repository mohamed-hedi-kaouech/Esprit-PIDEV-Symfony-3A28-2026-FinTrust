{% extends 'admin/back.html.twig' %}
{% block title %}Ajouter un client{% endblock %}

{% block breadcrumb %}
  <a href="{{ path('admin_dashboard') }}" class="text-muted small text-decoration-none">Dashboard</a>
  <i class="bi bi-chevron-right mx-1 text-muted small"></i>
  <a href="{{ path('admin_user_list') }}" class="text-muted small text-decoration-none">Utilisateurs</a>
  <i class="bi bi-chevron-right mx-1 text-muted small"></i>
  <span class="fw-semibold small">Ajouter un client</span>
{% endblock %}

{% block admin_content %}
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
  <div>
    <h1 class="ft-admin-page-title mb-2">Ajouter un nouveau client</h1>
    <p class="text-muted mb-0">Créez un compte client complet avec validation et statut initial.</p>
  </div>
  <a href="{{ path('admin_user_list') }}" class="btn btn-sm ft-btn-outline-primary">
    <i class="bi bi-arrow-left me-1"></i>Retour à la liste
  </a>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="ft-admin-card">
      <div class="ft-admin-card-header">
        <i class="bi bi-person-plus-fill me-2 text-primary"></i>Informations du client
      </div>
      <div class="ft-admin-card-body">
        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
          {{ form_errors(form) }}

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              {{ form_label(form.prenom, null, {label_attr: {class: 'form-label fw-semibold small'}}) }}
              {{ form_widget(form.prenom, {attr: {class: 'form-control ft-input'}}) }}
              <div class="text-danger small mt-1">{{ form_errors(form.prenom) }}</div>
            </div>
            <div class="col-md-6">
              {{ form_label(form.nom, null, {label_attr: {class: 'form-label fw-semibold small'}}) }}
              {{ form_widget(form.nom, {attr: {class: 'form-control ft-input'}}) }}
              <div class="text-danger small mt-1">{{ form_errors(form.nom) }}</div>
            </div>
          </div>

          <div class="mb-3">
            {{ form_label(form.email, null, {label_attr: {class: 'form-label fw-semibold small'}}) }}
            {{ form_widget(form.email, {attr: {class: 'form-control ft-input'}}) }}
            <div class="text-danger small mt-1">{{ form_errors(form.email) }}</div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              {{ form_label(form.numTel, null, {label_attr: {class: 'form-label fw-semibold small'}}) }}
              {{ form_widget(form.numTel, {attr: {class: 'form-control ft-input'}}) }}
              <div class="text-danger small mt-1">{{ form_errors(form.numTel) }}</div>
            </div>
            <div class="col-md-6">
              {{ form_label(form.plainPassword, null, {label_attr: {class: 'form-label fw-semibold small'}}) }}
              {{ form_widget(form.plainPassword, {attr: {class: 'form-control ft-input'}}) }}
              <div class="text-danger small mt-1">{{ form_errors(form.plainPassword) }}</div>
            </div>
          </div>

          <div class="row g-3 mb-4">
            <div class="col-md-6">
              {{ form_label(form.status, null, {label_attr: {class: 'form-label fw-semibold small'}}) }}
              {{ form_widget(form.status, {attr: {class: 'form-select ft-input'}}) }}
              <div class="text-danger small mt-1">{{ form_errors(form.status) }}</div>
            </div>
            <div class="col-md-6">
              {{ form_label(form.kycStatus, null, {label_attr: {class: 'form-label fw-semibold small'}}) }}
              {{ form_widget(form.kycStatus, {attr: {class: 'form-select ft-input'}}) }}
              <div class="text-danger small mt-1">{{ form_errors(form.kycStatus) }}</div>
            </div>
          </div>

          <button type="submit" class="btn ft-btn-primary">
            <i class="bi bi-check2-circle me-2"></i>Créer le client
          </button>
        {{ form_end(form) }}
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="ft-admin-card h-100">
      <div class="ft-admin-card-header">
        <i class="bi bi-stars me-2 text-primary"></i>Ce que l'admin contrôle
      </div>
      <div class="ft-admin-card-body">
        <div class="ft-admin-insight-list">
          <div class="ft-admin-insight-item">
            <strong>Activation immédiate</strong>
            <span>Le client peut être créé directement actif, en attente ou suspendu.</span>
          </div>
          <div class="ft-admin-insight-item">
            <strong>KYC préparé</strong>
            <span>Vous pouvez définir un statut KYC initial pour cadrer le workflow.</span>
          </div>
          <div class="ft-admin-insight-item">
            <strong>Suivi rapide</strong>
            <span>Après création, vous arrivez directement sur la fiche complète du client.</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
