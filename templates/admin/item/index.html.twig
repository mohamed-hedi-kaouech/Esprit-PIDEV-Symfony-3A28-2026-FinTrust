{% extends 'admin/base.html.twig' %}

{% block admin_body %}
    <h1>Items</h1>

    <a href="{{ path('admin_item_new') }}">Créer un nouvel item</a>

    <table class="table" style="width:100%; margin-top:1rem; border-collapse: collapse;">
        <thead>
            <tr>
                <th style="border-bottom:1px solid #ccc; padding:0.5rem; text-align:left;">Id</th>
                <th style="border-bottom:1px solid #ccc; padding:0.5rem; text-align:left;">Libellé</th>
                <th style="border-bottom:1px solid #ccc; padding:0.5rem; text-align:left;">Montant</th>
                <th style="border-bottom:1px solid #ccc; padding:0.5rem; text-align:left;">Catégorie</th>
                <th style="border-bottom:1px solid #ccc; padding:0.5rem; text-align:left;">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for item in items %}
            <tr>
                <td style="padding:0.5rem; border-bottom:1px solid #eee;">{{ item.idItem }}</td>
                <td style="padding:0.5rem; border-bottom:1px solid #eee;">{{ item.libelle }}</td>
                <td style="padding:0.5rem; border-bottom:1px solid #eee;">{{ item.montant }}</td>
                <td style="padding:0.5rem; border-bottom:1px solid #eee;">{{ item.categorieRel ? item.categorieRel.nomCategorie : '—' }}</td>
                <td style="padding:0.5rem; border-bottom:1px solid #eee;">
                    <a href="{{ path('admin_item_show', {'id': item.idItem}) }}">Voir</a>
                    <a href="{{ path('admin_item_edit', {'id': item.idItem}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" style="padding:0.5rem;">Aucun item trouvé.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
