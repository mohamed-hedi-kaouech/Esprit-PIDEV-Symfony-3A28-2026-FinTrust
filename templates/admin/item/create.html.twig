{% extends 'admin/back.html.twig' %}

{% block title %}Créer un Item{% endblock %}

{% block admin_content %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="h3 mb-0 text-gray-800">Créer un Nouvel Item</h1>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            {{ form_start(form) }}
            
            <div class="mb-3">
                {{ form_label(form.libelle, 'Libellé de l\'Item') }}
                {{ form_widget(form.libelle, {'attr': {'class': 'form-control'}}) }}
                {% if form.libelle.vars.errors|length > 0 %}
                    <div class="invalid-feedback d-block">
                        {% for error in form.libelle.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="mb-3">
                {{ form_label(form.montant, 'Montant (€)') }}
                {{ form_widget(form.montant, {'attr': {'class': 'form-control'}}) }}
                {% if form.montant.vars.errors|length > 0 %}
                    <div class="invalid-feedback d-block">
                        {% for error in form.montant.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="mb-3">
                {{ form_label(form.categorieRel, 'Catégorie') }}
                {{ form_widget(form.categorieRel, {'attr': {'class': 'form-control'}}) }}
                {% if form.categorieRel.vars.errors|length > 0 %}
                    <div class="invalid-feedback d-block">
                        {% for error in form.categorieRel.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Créer
                </button>
                <a href="{{ path('admin_item_list') }}" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Annuler
                </a>
            </div>
            
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
