{% extends 'admin/back.html.twig' %}

{% block title %}Confirmer la suppression{% endblock %}

{% block admin_content %}
<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="h3 mb-0 text-gray-800">Confirmer la suppression</h1>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header bg-danger">
            <h5 class="text-white mb-0">
                <i class="fas fa-exclamation-triangle"></i>
                Attention : Suppression définitive
            </h5>
        </div>
        <div class="card-body">
            <div class="alert alert-warning" role="alert">
                <h4 class="alert-heading">Êtes-vous sûr ?</h4>
                <p>Vous êtes sur le point de supprimer définitivement l'item <strong>"{{ item.libelle }}"</strong>.</p>
                <p class="mb-0">Cette action ne peut pas être annulée.</p>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <td><strong>ID :</strong></td>
                            <td>{{ item.idItem }}</td>
                        </tr>
                        <tr>
                            <td><strong>Libellé :</strong></td>
                            <td>{{ item.libelle }}</td>
                        </tr>
                        <tr>
                            <td><strong>Montant :</strong></td>
                            <td>{{ item.montant|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        <tr>
                            <td><strong>Catégorie :</strong></td>
                            <td>{{ item.categorieRel.nomCategorie }}</td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <form method="post" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.idItem) }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Oui, supprimer définitivement
                    </button>
                </form>
                <a href="{{ path('admin_item_list') }}" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Annuler
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}