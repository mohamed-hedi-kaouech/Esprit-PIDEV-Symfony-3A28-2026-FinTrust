{% extends 'admin/back.html.twig' %}

{% block title %}Liste des Items{% endblock %}

{% block admin_content %}
<div class="container-fluid mt-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h2 fw-bold text-dark mb-2">Gestion des Items</h1>
            <p class="text-muted">Créez et gérez vos articles budgétaires</p>
        </div>
        <div>
            <a href="{{ path('admin_item_create') }}" class="btn btn-primary btn-lg me-2">
                <i class="fas fa-plus me-2"></i>Nouvel Item
            </a>
            <a href="{{ path('admin_item_export') ~ '?' ~ app.request.queryString }}" class="btn btn-success btn-lg">
                <i class="fas fa-file-pdf me-2"></i>Exporter PDF
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <!-- Filtre -->
    <div class="card shadow-lg mb-4 border-0" style="border-radius: 12px;">
        <div class="card-header bg-secondary text-white" style="border-radius: 12px 12px 0 0; padding: 1.5rem;">
            <h5 class="m-0"><i class="fas fa-filter me-2"></i>Filtres et recherche</h5>
        </div>
        <div class="card-body">
            <form method="GET">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="search" class="form-label">Recherche par libellé</label>
                        <input type="text" class="form-control" id="search" name="search" 
                               value="{{ search }}" placeholder="Entrez un libellé...">
                    </div>
                    <div class="col-md-6">
                        <label for="categorie" class="form-label">Catégorie</label>
                        <select class="form-control" id="categorie" name="categorie">
                            <option value="">Toutes les catégories</option>
                            {% for categorie in categories %}
                            <option value="{{ categorie.idCategorie }}" 
                                    {% if categorieId == categorie.idCategorie %}selected{% endif %}>
                                {{ categorie.nomCategorie }}
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-md-3">
                        <label for="min_amount" class="form-label">Montant min</label>
                        <input type="number" step="0.01" class="form-control" id="min_amount" 
                               name="min_amount" value="{{ minAmount }}" placeholder="0.00">
                    </div>
                    <div class="col-md-3">
                        <label for="max_amount" class="form-label">Montant max</label>
                        <input type="number" step="0.01" class="form-control" id="max_amount" 
                               name="max_amount" value="{{ maxAmount }}" placeholder="0.00">
                    </div>
                    <div class="col-md-6 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-search"></i> Rechercher
                        </button>
                        <a href="{{ path('admin_item_list') }}" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Réinitialiser
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    {% if groupedItems|length > 0 %}
    {% for categoryName, categoryItems in groupedItems %}
    <div class="card shadow-lg mb-4 border-0" style="border-radius: 12px;">
        <div class="card-header bg-info text-white" style="border-radius: 12px 12px 0 0; padding: 1.5rem;">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="m-0"><i class="fas fa-folder me-2"></i>{{ categoryName }}</h5>
                <span class="badge bg-light text-info">{{ categoryItems|length }} item(s)</span>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Libellé</th>
                            <th>Montant</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in categoryItems %}
                        <tr>
                            <td>{{ item.idItem }}</td>
                            <td>{{ item.libelle }}</td>
                            <td>{{ item.montant|number_format(2, ',', ' ') }} €</td>
                            <td>
                                <a href="{{ path('admin_item_show', {'idItem': item.idItem}) }}" 
                                   class="btn btn-sm btn-info" title="Voir">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_item_edit', {'idItem': item.idItem}) }}" 
                                   class="btn btn-sm btn-warning" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="{{ path('admin_item_delete', {'idItem': item.idItem}) }}" 
                                      class="d-inline" 
                                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet item ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.idItem) }}">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {% endfor %}
    {% else %}
    <div class="alert alert-info" role="alert">
        <i class="fas fa-info-circle"></i> Aucun item trouvé. <a href="{{ path('admin_item_create') }}">Créer un nouveau</a>
    </div>
    {% endif %}
</div>

{% endblock %}
