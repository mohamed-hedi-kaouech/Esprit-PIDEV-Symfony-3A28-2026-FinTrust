{% extends 'admin/back.html.twig' %}
{% block title %}Dashboard Produits & Subscriptions{% endblock %}

{% block admin_content %}
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <script src="https://cdn.tailwindcss.com"></script>
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <style>
            body { font-family: 'Inter', sans-serif; }
        </style>
    </head>
<div class="min-h-screen bg-slate-50">

    {# Main Content #}
    <main class="ml-64 p-8">
        {# Breadcrumb #}
        <div class="mb-6 flex items-center gap-2 text-sm">
            <a href="{{ path('admin_dashboard') }}" class="text-slate-500 hover:text-emerald-600 flex items-center gap-1 font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Dashboard
            </a>
            <span class="text-slate-400">/</span>
            <a href="{{ path('admin_loan_review', {id: loan.loanId}) }}" class="text-slate-500 hover:text-emerald-600 font-medium">
                Loan #{{ loan.loanId }}
            </a>
            <span class="text-slate-400">/</span>
            <span class="text-slate-800 font-semibold">Repayment History</span>
        </div>

        {# Header #}
        <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
            <div class="flex justify-between items-start">
                <div>
                    <h1 class="text-3xl font-bold text-slate-800">Repayment History</h1>
                    <p class="text-slate-500 mt-1">Loan #{{ loan.loanId }} - {{ loan.loanType }}</p>
                </div>
                <span class="px-3 py-1 bg-emerald-100 text-emerald-800 rounded-full text-sm font-bold">
                    {{ loan.status }}
                </span>
            </div>
        </div>

        {# Summary Cards #}
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
            <div class="bg-white rounded-lg shadow-sm p-4 border-l-4 border-emerald-500">
                <p class="text-xs text-slate-500 uppercase font-semibold">Paid Installments</p>
                <p class="text-2xl font-bold text-emerald-600">{{ stats.paidCount }}</p>
            </div>
            <div class="bg-white rounded-lg shadow-sm p-4 border-l-4 border-amber-500">
                <p class="text-xs text-slate-500 uppercase font-semibold">Unpaid</p>
                <p class="text-2xl font-bold text-amber-600">{{ stats.unpaidCount }}</p>
            </div>
            <div class="bg-white rounded-lg shadow-sm p-4 border-l-4 border-blue-500">
                <p class="text-xs text-slate-500 uppercase font-semibold">Total Paid</p>
                <p class="text-2xl font-bold text-blue-600">${{ stats.totalPaid|number_format(2) }}</p>
            </div>
            <div class="bg-white rounded-lg shadow-sm p-4 border-l-4 border-red-500">
                <p class="text-xs text-slate-500 uppercase font-semibold">Remaining Due</p>
                <p class="text-2xl font-bold text-red-600">${{ stats.totalUnpaid|number_format(2) }}</p>
            </div>
        </div>

        {# Progress Bar #}
        <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
            <div class="flex justify-between items-center mb-2">
                <span class="text-sm font-medium text-slate-700">Repayment Progress</span>
                <span class="text-sm font-bold text-emerald-600">{{ stats.progressPercent }}%</span>
            </div>
            <div class="w-full h-4 bg-slate-200 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full" style="width: {{ stats.progressPercent }}%"></div>
            </div>
            <div class="flex justify-between mt-2 text-xs text-slate-500">
                <span>{{ stats.paidCount }} paid</span>
                <span>{{ stats.paidCount + stats.unpaidCount }} total</span>
            </div>
        </div>

        {# Next Payment Alert #}
        {% if nextUnpaid and loan.status != 'COMPLETED' %}
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <span class="bg-amber-100 text-amber-700 p-2 rounded-lg">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </span>
                    <div>
                        <p class="text-amber-800 font-semibold">Next Payment Due</p>
                        <p class="text-amber-600 text-sm">Month {{ nextUnpaid.month }} - ${{ nextUnpaid.monthlyPayment|number_format(2) }}</p>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# Repayment Table #}
        <div class="bg-white rounded-xl shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
                <h2 class="text-lg font-bold text-slate-800">Complete Amortization Schedule</h2>
                {% if stats.isCompleted %}
                    <span class="bg-purple-100 text-purple-800 text-xs font-bold px-3 py-1 rounded-full">✓ Fully Paid</span>
                {% endif %}
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-slate-50 text-slate-600 text-xs uppercase tracking-wider">
                        <tr>
                            <th class="px-6 py-3 text-left font-semibold">Month</th>
                            <th class="px-6 py-3 text-left font-semibold">Starting Balance</th>
                            <th class="px-6 py-3 text-left font-semibold">Payment</th>
                            <th class="px-6 py-3 text-left font-semibold">Principal</th>
                            <th class="px-6 py-3 text-left font-semibold">Interest</th>
                            <th class="px-6 py-3 text-left font-semibold">Remaining</th>
                            <th class="px-6 py-3 text-center font-semibold">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        {% for repayment in repayments %}
                        <tr class="hover:bg-slate-50 transition-colors {{ repayment.status == 'PAID' ? 'bg-emerald-50/30' : '' }}">
                            <td class="px-6 py-4 font-medium text-slate-800">Month {{ repayment.month }}</td>
                            <td class="px-6 py-4 text-slate-600">${{ repayment.startingBalance|number_format(2) }}</td>
                            <td class="px-6 py-4 font-bold text-slate-800">${{ repayment.monthlyPayment|number_format(2) }}</td>
                            <td class="px-6 py-4 text-emerald-600">${{ repayment.capitalPart|number_format(2) }}</td>
                            <td class="px-6 py-4 text-amber-600">${{ repayment.interestPart|number_format(2) }}</td>
                            <td class="px-6 py-4 text-slate-600">${{ repayment.remainingBalance|number_format(2) }}</td>
                            <td class="px-6 py-4 text-center">
                                {% if repayment.status == 'PAID' %}
                                    <span class="inline-flex items-center gap-1 px-3 py-1 bg-emerald-100 text-emerald-700 rounded-full text-xs font-bold">
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                                        PAID
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1 px-3 py-1 bg-amber-100 text-amber-700 rounded-full text-xs font-bold">
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                                        UNPAID
                                    </span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# Back Button #}
        <div class="mt-6">
            <a href="{{ path('admin_loan_review', {id: loan.loanId}) }}" class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-800 font-medium">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Back to Loan Details
            </a>
        </div>
    </main>
</div>
{% endblock %}