{% extends 'front/front.html.twig' %}
{% block title %}List Produit{% endblock %}

{% block body %}
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <style>
            body { font-family: 'Inter', sans-serif; }
        </style>
    </head>
<div class="min-h-screen bg-gray-100">
    {# Header Fintech Style #}
    <header class="bg-white shadow-sm border-b-4 border-green-700">
        <div class="max-w-6xl mx-auto px-4 py-4 flex items-center gap-4">
            <div class="flex items-center gap-2">
                <img src="{{ asset('images/fintech-logo.png') }}" alt="" class="h-16">
                <div>
                    <p class="text-xs text-red-600 font-bold">République Tunisienne</p>
                    <p class="text-sm text-green-800 font-bold">Fintech</p>
                </div>
            </div>
            <h1 class="ml-auto text-2xl font-bold text-green-800">Simuler Vos Prêts Fintech</h1>
        </div>
    </header>

    {# Main Content #}
    <main class="max-w-6xl mx-auto px-4 py-8">
        {# Loan Type Cards #}
        <div class="grid grid-cols-3 gap-4 mb-8">
            <div class="loan-card bg-green-500 rounded-xl p-6 text-white text-center cursor-pointer transition-transform hover:scale-105" data-type="PERSONNEL" onclick="selectLoanType('PERSONNEL')">
                <svg class="w-12 h-12 mx-auto mb-3" fill="currentColor" viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>
                <h3 class="font-bold text-lg">Prêt Personnel</h3>
                <p class="text-sm opacity-90 mt-2">Max: 25 000 TND</p>
            </div>
            
            <div class="loan-card bg-sky-400 rounded-xl p-6 text-white text-center cursor-pointer transition-transform hover:scale-105" data-type="VOITURE" onclick="selectLoanType('VOITURE')">
                <svg class="w-12 h-12 mx-auto mb-3" fill="currentColor" viewBox="0 0 24 24"><path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/></svg>
                <h3 class="font-bold text-lg">Prêt Voiture</h3>
                <p class="text-sm opacity-90 mt-2">Max: 50 000 TND</p>
            </div>
            
            <div class="loan-card bg-red-400 rounded-xl p-6 text-white text-center cursor-pointer transition-transform hover:scale-105" data-type="LOGEMENT" onclick="selectLoanType('LOGEMENT')">
                <svg class="w-12 h-12 mx-auto mb-3" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
                <h3 class="font-bold text-lg">Prêt Logement</h3>
                <p class="text-sm opacity-90 mt-2">Max: 200 000 TND</p>
            </div>
        </div>

        {# Simulator Form #}
        <div class="bg-white rounded-xl shadow-lg p-8">
            {{ form_start(form, {'attr': {'id': 'simulator-form'}}) }}
                
                <div class="grid grid-cols-2 gap-6 mb-6">
                    {# Amount #}
                    <div>
                        {{ form_label(form.amount, 'Montant du Prêt:', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                        <div class="flex items-center gap-2">
                            {{ form_widget(form.amount, {'attr': {'class': 'w-full border-2 border-gray-300 rounded-lg px-4 py-2 focus:border-green-500 focus:outline-none', 'id': 'loan-amount'}}) }}
                            <span class="text-gray-500 font-medium">TND</span>
                        </div>
                        {{ form_errors(form.amount) }}
                        <p class="text-xs text-red-500 mt-1" id="amount-error"></p>
                    </div>

                    {# Duration Slider #}
                    <div>
                        {{ form_label(form.duration, 'Durée de Remboursement:', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                        <div class="flex items-center gap-4">
                            {{ form_widget(form.duration, {'attr': {'class': 'flex-1 h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-green-600', 'id': 'loan-duration', 'oninput': 'updateDurationLabel(this.value)'}}) }}
                            <span class="text-green-700 font-bold text-lg w-24" id="duration-label">12 mois</span>
                        </div>
                        <div class="flex justify-between text-xs text-gray-500 mt-1">
                            <span>6 mois</span>
                            <span>36 mois</span>
                        </div>
                    </div>
                </div>

                {# Interest Rate (Read Only) #}
                <div class="mb-6 p-4 bg-green-50 rounded-lg border border-green-200">
                    <div class="flex items-center justify-between">
                        <span class="text-green-800 font-medium">Taux d'intérêt:</span>
                        <span class="text-2xl font-bold text-green-700">{{ form.vars.data.interestRate|default(8.25) }}%</span>
                    </div>
                    {{ form_widget(form.interestRate, {'attr': {'class': 'hidden'}}) }}
                </div>

                {# Hidden Loan Type #}
                {{ form_widget(form.loanType, {'attr': {'id': 'selected-loan-type'}}) }}

                <div class="text-center">
                    <button type="submit" class="bg-green-700 hover:bg-green-800 text-white font-bold py-3 px-8 rounded-lg transition-colors shadow-lg">
                        Lancer la Simulation →
                    </button>
                </div>

            {{ form_end(form) }}
        </div>
    </main>

    <footer class="max-w-6xl mx-auto px-4 py-4 text-center text-xs text-gray-500">
        © 2026 fintech - Tous les droits sont réservés
    </footer>
</div>

<script>
    // Loan type selection
    function selectLoanType(type) {
        document.querySelectorAll('.loan-card').forEach(card => {
            card.classList.remove('ring-4', 'ring-offset-2', 'ring-green-400');
        });
        document.querySelector(`[data-type="${type}"]`).classList.add('ring-4', 'ring-offset-2', 'ring-green-400');
        document.getElementById('selected-loan-type').value = type;
        
        // Update max amount based on type
        const maxAmounts = {
            'PERSONNEL': 25000,
            'VOITURE': 50000,
            'LOGEMENT': 200000
        };
        document.getElementById('loan-amount').max = maxAmounts[type];
    }

    // Duration label update
    function updateDurationLabel(value) {
        document.getElementById('duration-label').textContent = value + ' mois';
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
        selectLoanType('PERSONNEL');
    });
</script>
{% endblock %}