{# templates/loan/preview.html.twig #}
{% extends 'html/Loan/base.html.twig' %}

{% block title %}Prévisualisation du Prêt{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-100 py-8">
    <div class="max-w-5xl mx-auto px-4">
        
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
            {# Header #}
            <div class="bg-green-700 text-white p-6">
                <h1 class="text-2xl font-bold">Prévisualisation de votre demande</h1>
                <p class="mt-2 opacity-90">Vérifiez les détails avant de confirmer</p>
            </div>

            <div class="p-6">
                {# Loan Summary #}
                <div class="grid grid-cols-4 gap-4 mb-8">
                    <div class="bg-green-50 p-4 rounded-lg text-center">
                        <p class="text-sm text-gray-600">Type</p>
                        <p class="text-lg font-bold text-green-800">{{ loan.loanType }}</p>
                    </div>
                    <div class="bg-blue-50 p-4 rounded-lg text-center">
                        <p class="text-sm text-gray-600">Montant</p>
                        <p class="text-lg font-bold text-blue-800">{{ loan.amount|number_format(3) }} TND</p>
                    </div>
                    <div class="bg-purple-50 p-4 rounded-lg text-center">
                        <p class="text-sm text-gray-600">Durée</p>
                        <p class="text-lg font-bold text-purple-800">{{ loan.duration }} mois</p>
                    </div>
                    <div class="bg-amber-50 p-4 rounded-lg text-center">
                        <p class="text-sm text-gray-600">Taux</p>
                        <p class="text-lg font-bold text-amber-800">{{ loan.interestRate }}%</p>
                    </div>
                </div>

                {# Results #}
                <div class="grid grid-cols-2 gap-6 mb-8">
                    <div class="bg-green-100 p-6 rounded-xl text-center border-2 border-green-300">
                        <p class="text-green-800 text-sm font-medium uppercase">Mensualité</p>
                        <p class="text-4xl font-bold text-green-700 mt-2">{{ monthlyPayment|number_format(3) }}</p>
                        <p class="text-green-600">TND / mois</p>
                    </div>
                    <div class="bg-blue-100 p-6 rounded-xl text-center border-2 border-blue-300">
                        <p class="text-blue-800 text-sm font-medium uppercase">Coût Total du Prêt</p>
                        <p class="text-4xl font-bold text-blue-700 mt-2">{{ totalCost|number_format(3) }}</p>
                        <p class="text-blue-600">TND</p>
                    </div>
                </div>

                <p class="text-center text-gray-600 mb-6">
                    Intérêts totaux: <span class="font-bold text-amber-600">{{ totalInterest|number_format(3) }} TND</span>
                </p>

                {# Amortization Table #}
                <h3 class="text-lg font-bold text-gray-800 mb-4">Tableau d'amortissement</h3>
                <div class="overflow-x-auto rounded-lg border">
                    <table class="w-full text-sm">
                        <thead class="bg-green-700 text-white">
                            <tr>
                                <th class="px-3 py-2">Mois</th>
                                <th class="px-3 py-2">Capital dû</th>
                                <th class="px-3 py-2">Principal</th>
                                <th class="px-3 py-2">Intérêts</th>
                                <th class="px-3 py-2">Mensualité</th>
                                <th class="px-3 py-2">Reste dû</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            {% for row in repaymentPlan %}
                            <tr class="hover:bg-gray-50 {{ loop.index % 2 == 0 ? 'bg-gray-50' : '' }}">
                                <td class="px-3 py-2 font-medium">{{ row.month }}</td>
                                <td class="px-3 py-2">{{ row.startingBalance|number_format(3) }}</td>
                                <td class="px-3 py-2 text-green-600">{{ row.capitalPart|number_format(3) }}</td>
                                <td class="px-3 py-2 text-amber-600">{{ row.interestPart|number_format(3) }}</td>
                                <td class="px-3 py-2 font-bold">{{ row.monthlyPayment|number_format(3) }}</td>
                                <td class="px-3 py-2">{{ row.remainingBalance|number_format(3) }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# Action Buttons #}
                <div class="flex gap-4 mt-8 justify-center">
                    <a href="{{ path('loan_simulator') }}" class="bg-gray-500 hover:bg-gray-600 text-white font-bold py-3 px-6 rounded-lg transition-colors">
                        ← Modifier
                    </a>
                    <form action="{{ path('loan_confirm') }}" method="POST">
                        <input type="hidden" name="_token" value="{{ csrf_token('confirm_loan') }}">
                        <button type="submit" class="bg-green-700 hover:bg-green-800 text-white font-bold py-3 px-8 rounded-lg transition-colors shadow-lg">
                            Confirmer la demande ✓
                        </button>
                    </form>
                </div>

                <p class="text-center text-sm text-gray-500 mt-4">
                    En confirmant, votre demande sera soumise pour approbation par l'administrateur.
                </p>
            </div>
        </div>

    </div>
</div>
{% endblock %}