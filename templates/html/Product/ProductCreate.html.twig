<!DOCTYPE html>

<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Modifier le Produit</title>

  <link rel="stylesheet" href="{{ asset('css/Product/StyleEditProduct.css') }}">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

<header class="header">
    <div class="header-left">
        <a href="{{ path('product_list') }}" class="btn-back">← Retour</a>
        <span class="header-title">Modifier le Produit</span>
    </div>
</header>

<div class="page-wrapper">

```
{# Flash messages #}
{% for msg in app.flashes('success') %}
    <script>
        Swal.fire({
            icon: 'success',
            title: '{{ msg }}',
            showConfirmButton: false,
            timer: 2000
        });
    </script>
{% endfor %}

{% for msg in app.flashes('error') %}
    <script>
        Swal.fire({
            icon: 'error',
            title: 'Erreur',
            text: '{{ msg }}'
        });
    </script>
{% endfor %}

<div class="section-heading">
    <h2>Creation du Produit</h2>
    <hr class="divider">
</div>

<div class="form-card">
    <form method="POST" action="{{ path('CreateProduct') }}">

        <input type="hidden" name="_token" value="{{ csrf_token('CreateProduct') }}">

        <!-- Category -->
        <div class="form-group">
            <label class="field-label">Nouvelle Catégorie</label>
            <select name="category" class="form-select">
                <option value="">Sélectionner une catégorie</option>

                {% set categories = [
                    'COMPTE_COURANT','COMPTE_EPARGNE','COMPTE_PREMIUM',
                    'COMPTE_JEUNE','COMPTE_ENTREPRISE',
                    'CARTE_DEBIT','CARTE_CREDIT','CARTE_PREMIUM',
                    'CARTE_VIRTUELLE',
                    'EPARGNE_CLASSIQUE','EPARGNE_LOGEMENT','DEPOT_A_TERME',
                    'PLACEMENT_INVESTISSEMENT',
                    'ASSURANCE_VIE','ASSURANCE_HABITATION','ASSURANCE_VOYAGE'
                ] %}
                {% for cat in categories %}
                    <option value="{{ cat }}">
                        {{ cat }}
                    </option>
                {% endfor %}                
            </select>
        </div>

        <!-- Price -->
        <div class="form-group">
            <label class="field-label">Nouveau Prix (DT)</label>
            <div class="price-row">
                <input type="text" name="price" class="form-input" value="0">
                <span class="currency-tag">DT</span>
            </div>
        </div>

        <!-- Description -->
        <div class="form-group">
            <label class="field-label">Nouvelle Description</label>
            <textarea name="description" class="form-textarea"placeholder="Description"></textarea>
        </div>

        <!-- Date -->
        <div class="form-group">
            <label class="field-label">Date de Création</label>
            <input type="date" class="form-input" id="creationDate" disabled>
        </div>
        </div>

        <hr class="form-divider">

        <div class="btn-row">
            <button type="submit" class="btn btn-primary">
                ✓ Ajouter le Produit
            </button>

            <a href="{{ path('product_list') }}" class="btn btn-secondary">
                Annuler
            </a>
        </div>

    </form>
</div>
```

</div>

<script>
    // Set today's date in YYYY-MM-DD format
    const today = new Date();
    const yyyy = today.getFullYear();
    const mm = String(today.getMonth() + 1).padStart(2, '0'); // Months are 0-based
    const dd = String(today.getDate()).padStart(2, '0');
    document.getElementById('creationDate').value = `${yyyy}-${mm}-${dd}`;
</script>

</body>
</html>
