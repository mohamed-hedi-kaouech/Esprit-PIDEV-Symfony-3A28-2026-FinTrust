{% extends 'admin/back.html.twig' %}

{% block title %}Modifier l'abonnement{% endblock %}

{% block admin_content %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Modifier l'abonnement</h1>
            <p class="text-muted mb-0">
                Abonnement #{{ subscription.subscriptionId }} pour
                {{ subscription.clientUser.fullName }}
            </p>
        </div>
        <a href="{{ path('subscription_list') }}" class="btn btn-outline-secondary">
            Retour a la liste
        </a>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">Informations actuelles</h2>

                    <div class="mb-3">
                        <div class="text-muted small">Client</div>
                        <div class="fw-semibold">{{ subscription.clientUser.fullName }}</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Produit</div>
                        <div class="fw-semibold">
                            #{{ subscription.productObj.productId }} - {{ subscription.productObj.category }}
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Prix du produit</div>
                        <div class="fw-semibold">{{ subscription.productObj.price|number_format(2, '.', ' ') }} DT</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Date de souscription</div>
                        <div class="fw-semibold">{{ subscription.subscriptionDate|date('d/m/Y') }}</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Date d'expiration</div>
                        <div class="fw-semibold">{{ subscription.expirationDate|date('d/m/Y') }}</div>
                    </div>

                    <div class="mb-0">
                        <div class="text-muted small">Statut</div>
                        <div class="fw-semibold">{{ subscription.status }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h2 class="h5 mb-4">Mettre a jour les informations</h2>

                    {{ form_start(form) }}
                        <div class="row g-3">
                            <div class="col-md-6">
                                {{ form_label(form.clientUser, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                                {{ form_widget(form.clientUser, { attr: { class: 'form-select' } }) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.clientUser) }}</div>
                            </div>

                            <div class="col-md-6">
                                {{ form_label(form.productObj, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                                {{ form_widget(form.productObj, { attr: { class: 'form-select' } }) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.productObj) }}</div>
                            </div>

                            <div class="col-md-6">
                                {{ form_label(form.type, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                                {{ form_widget(form.type, { attr: { class: 'form-select' } }) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.type) }}</div>
                            </div>

                            <div class="col-md-6">
                                {{ form_label(form.status, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                                {{ form_widget(form.status, { attr: { class: 'form-select' } }) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.status) }}</div>
                            </div>

                            <div class="col-md-6">
                                {{ form_label(form.subscriptionDate, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                                {{ form_widget(form.subscriptionDate, { attr: { class: 'form-control' } }) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.subscriptionDate) }}</div>
                            </div>

                            <div class="col-md-6">
                                {{ form_label(form.expirationDate, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                                {{ form_widget(form.expirationDate, { attr: { class: 'form-control' } }) }}
                                <div class="text-danger small mt-1">{{ form_errors(form.expirationDate) }}</div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                Enregistrer les modifications
                            </button>
                            <a href="{{ path('subscription_list') }}" class="btn btn-light border">
                                Annuler
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
