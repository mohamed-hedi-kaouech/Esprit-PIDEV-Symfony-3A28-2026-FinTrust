{% extends 'admin/back.html.twig' %}

{% block title %}Catalogue produits{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300&family=Fraunces:wght@700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('css/Product/StyleProduct.css') }}">
  <style>
    {% for i in 1..50 %}
    .pl-card:nth-child({{ i }}) { animation-delay: {{ (i - 1) * 0.04 }}s; }
    {% endfor %}
  </style>
{% endblock %}

{% block admin_content %}
  {% set searchTerm = app.request.query.get('search') %}
  {% set filterCat = app.request.query.get('category') %}
  {% set sortValue = app.request.query.get('sort') %}
  {% set categories = [] %}

  {% for product in products %}
    {% if product.category not in categories %}
      {% set categories = categories|merge([product.category]) %}
    {% endif %}
  {% endfor %}

  <div class="pl-page">
    <div class="pl-bg-glow pl-bg-glow--one"></div>
    <div class="pl-bg-glow pl-bg-glow--two"></div>

    <section class="pl-hero">
      <div class="pl-hero__content">
        <span class="pl-hero__eyebrow">
          <span class="pl-hero__eyebrow-icon"><i class="bi bi-stars"></i></span>
          Catalogue premium
        </span>
        <h1 class="pl-title">Nos Produits</h1>
        <p class="pl-subtitle">
          Pilotez votre catalogue bancaire avec une interface plus elegante, plus lisible et plus dynamique.
          Recherchez rapidement, filtrez par categorie et accedez a vos actions d'administration en un coup d'oeil.
        </p>

        <div class="pl-hero-metrics">
          <div class="pl-hero-metric">
            <span class="pl-hero-metric__label">Produits visibles</span>
            <span class="pl-hero-metric__value">{{ products|length }}</span>
          </div>
          <div class="pl-hero-metric">
            <span class="pl-hero-metric__label">Categories</span>
            <span class="pl-hero-metric__value">{{ categories|length }}</span>
          </div>
          <div class="pl-hero-metric">
            <span class="pl-hero-metric__label">Recherche active</span>
            <span class="pl-hero-metric__value">{{ searchTerm ? 'Oui' : 'Non' }}</span>
          </div>
        </div>
      </div>

      <div class="pl-hero__side">
        <div class="pl-count">{{ products|length }} produit{{ products|length != 1 ? 's' : '' }}</div>
        <div class="pl-hero-note">
          <span class="pl-hero-note__title">Action rapide</span>
          <p>Ajoutez un nouveau produit, mettez a jour les offres existantes et gardez une presentation bancaire haut de gamme.</p>
        </div>
        <a href="{{ path('CreateProduct') }}" class="pl-buy-btn">
          <i class="bi bi-plus-lg"></i>
          Nouveau produit
        </a>
      </div>
    </section>

    <form method="GET" action="{{ path('product_list') }}" class="pl-filter-card">
      <div class="pl-filter-card__grid">
        <div class="pl-search-field">
          <label class="pl-filter-label" for="product-search">Recherche</label>
          <div class="pl-search-field__control">
            <span class="pl-search-field__icon"><i class="bi bi-search"></i></span>
            <input
              id="product-search"
              class="pl-input"
              type="text"
              name="search"
              placeholder="Rechercher un produit, une categorie ou une description..."
              value="{{ searchTerm }}"
            />
          </div>
        </div>

        <div>
          <label class="pl-filter-label" for="product-category">Categorie</label>
          <div class="pl-select-wrap">
            <select id="product-category" name="category" class="pl-select">
              <option value="">Toutes</option>
              {% for cat in categories|sort %}
                <option value="{{ cat }}" {% if filterCat == cat %}selected{% endif %}>
                  {{ cat|replace({'_': ' '})|title }}
                </option>
              {% endfor %}
            </select>
          </div>
        </div>

        <div>
          <label class="pl-filter-label" for="product-sort">Trier</label>
          <div class="pl-select-wrap">
            <select id="product-sort" name="sort" class="pl-select">
              <option value="">Par defaut</option>
              <option value="price_asc" {% if sortValue == 'price_asc' %}selected{% endif %}>Prix croissant</option>
              <option value="price_desc" {% if sortValue == 'price_desc' %}selected{% endif %}>Prix decroissant</option>
              <option value="date_desc" {% if sortValue == 'date_desc' %}selected{% endif %}>Plus recent</option>
              <option value="date_asc" {% if sortValue == 'date_asc' %}selected{% endif %}>Plus ancien</option>
            </select>
          </div>
        </div>

        <div class="pl-filter-actions">
          <button type="submit" class="pl-btn pl-btn-primary">
            <i class="bi bi-funnel-fill"></i>
            Rechercher
          </button>
          <a href="{{ path('product_list') }}" class="pl-btn pl-btn-ghost">
            <i class="bi bi-x-lg"></i>
            Reset
          </a>
        </div>
      </div>

      {% if searchTerm or filterCat %}
        <div class="pl-active-bar">
          <span class="pl-active-bar__title">Filtres actifs</span>
          <div class="pl-active-chips">
            {% if searchTerm %}
              <span class="pl-active-chip"><i class="bi bi-search me-2"></i>{{ searchTerm }}</span>
            {% endif %}
            {% if filterCat %}
              <span class="pl-active-chip"><i class="bi bi-tag me-2"></i>{{ filterCat|replace({'_': ' '})|title }}</span>
            {% endif %}
            {% if sortValue %}
              <span class="pl-active-chip"><i class="bi bi-arrow-down-up me-2"></i>{{ sortValue|replace({'_': ' '})|title }}</span>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </form>

    <div class="pl-results-bar">
      <div class="pl-results-bar__left">
        <span class="pl-results-bar__count">{{ products|length }}</span>
        <span class="pl-results-bar__label">resultat{{ products|length > 1 ? 's' : '' }} disponibles</span>
      </div>
      <span class="pl-results-pill">
        <i class="bi bi-lightning-charge-fill me-2"></i>
        Gestion produits FinTrust
      </span>
    </div>

    {% set tones = ['tone-blue', 'tone-green', 'tone-amber', 'tone-purple', 'tone-coral'] %}

    <div class="pl-grid">
      {% if products is empty %}
        <div class="pl-empty">
          <div class="pl-empty__icon"><i class="bi bi-inbox-fill"></i></div>
          <h2 class="pl-empty__title">Aucun produit trouve</h2>
          <p class="pl-empty__text">
            Ajustez vos filtres ou creez une nouvelle offre pour enrichir le catalogue avec une presentation claire et professionnelle.
          </p>
          <a href="{{ path('CreateProduct') }}" class="pl-buy-btn">
            <i class="bi bi-plus-lg"></i>
            Ajouter un produit
          </a>
        </div>
      {% else %}
        {% for product in products %}
          {% set tone = tones[loop.index0 % tones|length] %}

          <article class="pl-card {{ tone }}">
            <div class="pl-card__cover">
              <div class="pl-card__meta">
                <div class="pl-card__icon">
                  {{ product.category|slice(0, 2)|upper }}
                </div>
                <div class="pl-card__meta-right">
                  <span class="pl-card__badge">{{ product.category|replace({'_': ' '})|title }}</span>
                  <span class="pl-card__date">{{ product.createdAt|date('d/m/Y') }}</span>
                </div>
              </div>
              <div class="pl-card__cover-gloss"></div>
            </div>

            <div class="pl-card__body">
              <h3 class="pl-card__title">{{ product.description|length > 30 ? product.description|slice(0, 30) ~ '...' : product.description }}</h3>
              <p class="pl-card__description" title="{{ product.description }}">
                {{ product.description }}
              </p>

              <div class="pl-card__highlights">
                <span class="pl-card__highlight">
                  <i class="bi bi-tag-fill"></i>
                  {{ product.category|replace({'_': ' '})|title }}
                </span>
                <span class="pl-card__highlight">
                  <i class="bi bi-calendar-event"></i>
                  {{ product.createdAt|date('d/m/Y') }}
                </span>
              </div>
            </div>

            <div class="pl-card__footer">
              <div class="pl-card__price-block">
                <span class="pl-card__price-label">Tarif</span>
                <div class="pl-card__price">
                  {{ product.price|number_format(2, ',', ' ') }}<span class="pl-card__currency">DT</span>
                </div>
              </div>

              <div class="d-flex flex-column gap-2">
                <a class="pl-buy-btn" href="{{ path('EditProduct', {id: product.productId}) }}">
                  <i class="bi bi-pencil-square"></i>
                  Modifier
                </a>
                <form method="post" action="{{ path('product_delete', {id: product.productId}) }}" class="delete-form">
                  <button class="pl-btn pl-btn-ghost" type="button">
                    <i class="bi bi-trash3"></i>
                    Supprimer
                  </button>
                </form>
              </div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}

  {% set flashSuccesses = app.flashes('success') %}
  {% set flashErrors = app.flashes('error') %}

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="{{ asset('js/Product/ScriptProduct.js') }}" defer></script>

  <script>
    {% if flashSuccesses is not empty %}
    window.addEventListener('load', function () {
      Swal.fire({
        icon: 'success',
        title: '{{ flashSuccesses|first|e('js') }}',
        showConfirmButton: false,
        timer: 2500,
        timerProgressBar: true,
        background: '#ffffff',
        color: '#0f172a',
        iconColor: '#22c55e'
      });
    });
    {% endif %}

    {% if flashErrors is not empty %}
    window.addEventListener('load', function () {
      Swal.fire({
        icon: 'error',
        title: '{{ flashErrors|first|e('js') }}',
        showConfirmButton: true,
        background: '#ffffff',
        color: '#0f172a',
        confirmButtonColor: '#2563eb'
      });
    });
    {% endif %}
  </script>
{% endblock %}
