<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
</head>
<body style="margin:0;padding:0;background:#f6f7fb;font-family:Arial,sans-serif;color:#1f2937;">
  <div style="max-width:640px;margin:32px auto;padding:0 16px;">
    <div style="background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 12px 32px rgba(15,23,42,0.08);">
      <div style="background:linear-gradient(135deg,#0f766e,#0ea5e9);padding:28px 32px;color:#ffffff;">
        <div style="font-size:13px;letter-spacing:0.08em;text-transform:uppercase;opacity:0.9;">FinTrust Wallet</div>
        <h1 style="margin:10px 0 0;font-size:26px;line-height:1.2;">{{ title }}</h1>
      </div>

      <div style="padding:32px;">
        <p style="margin:0 0 20px;font-size:15px;line-height:1.7;">{{ intro }}</p>

        <table role="presentation" style="width:100%;border-collapse:collapse;margin:0 0 24px;">
          <tr>
            <td style="padding:12px 0;border-bottom:1px solid #e5e7eb;color:#6b7280;">Montant</td>
            <td style="padding:12px 0;border-bottom:1px solid #e5e7eb;text-align:right;font-weight:700;">{{ amount|number_format(2, ',', ' ') }} {{ devise }}</td>
          </tr>
          <tr>
            <td style="padding:12px 0;border-bottom:1px solid #e5e7eb;color:#6b7280;">{{ counterparty_label }}</td>
            <td style="padding:12px 0;border-bottom:1px solid #e5e7eb;text-align:right;font-weight:600;">{{ counterparty_value }}</td>
          </tr>
          <tr>
            <td style="padding:12px 0;border-bottom:1px solid #e5e7eb;color:#6b7280;">Date et heure</td>
            <td style="padding:12px 0;border-bottom:1px solid #e5e7eb;text-align:right;">{{ datetime|date('d/m/Y H:i') }}</td>
          </tr>
          <tr>
            <td style="padding:12px 0;color:#6b7280;">Libelle</td>
            <td style="padding:12px 0;text-align:right;">{{ label ?: 'Aucun libelle' }}</td>
          </tr>
        </table>

        <p style="margin:0;font-size:14px;line-height:1.7;color:#4b5563;">
          Cet email confirme l operation enregistree dans votre espace FinTrust.
        </p>
      </div>
    </div>
  </div>
</body>
</html>
