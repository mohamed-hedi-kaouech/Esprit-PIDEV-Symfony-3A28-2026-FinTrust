{% extends 'front/front.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block body %}
<div class="ft-auth-page">
  <div class="container">
    <div class="row justify-content-center align-items-center min-vh-100 py-5">
      <div class="col-12 col-lg-10">
        <div class="ft-reset-shell">
          <section class="ft-reset-side">
            <span class="ft-verify-kicker">
              <i class="bi bi-shield-check"></i> Etape finale
            </span>
            <h1 class="ft-auth-title mb-3">Choisissez un nouveau mot de passe</h1>
            <p class="ft-verify-copy mb-4">
              Votre nouvelle cle d acces doit etre robuste et unique. Une fois enregistree,
              les anciennes sessions seront forcees a se reconnecter.
            </p>
          </section>

          <section class="ft-auth-card ft-reset-card">
            <div class="text-center mb-4">
              <div class="ft-auth-logo mb-3">
                <svg viewBox="0 0 40 40" fill="none" width="48" height="48">
                  <rect width="40" height="40" rx="10" fill="#1560BD"/>
                  <path d="M10 28V18l10-8 10 8v10H24v-6h-8v6H10Z" fill="white"/>
                </svg>
              </div>
              <h2 class="ft-auth-title ft-verify-title">Nouveau mot de passe</h2>
              <p class="text-muted mb-0">Demande verifiee via {{ resetRequest.channel == 'EMAIL' ? 'e-mail' : resetRequest.channel == 'WHATSAPP' ? 'WhatsApp' : 'SMS' }}.</p>
            </div>

            {{ form_start(resetPasswordForm, {attr: {novalidate: 'novalidate'}}) }}
              <div class="mb-3">
                {{ form_label(resetPasswordForm.plainPassword.first, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                {{ form_widget(resetPasswordForm.plainPassword.first, {attr: {class: 'form-control ft-input', autocomplete: 'new-password', placeholder: 'Minimum 12 caracteres'}}) }}
                <div class="form-text">Majuscule, minuscule, chiffre et caractere special requis.</div>
                {% if resetPasswordForm.plainPassword.first.vars.errors|length > 0 %}
                  <div class="text-danger small mt-1">{{ form_errors(resetPasswordForm.plainPassword.first) }}</div>
                {% endif %}
              </div>

              <div class="mb-3">
                {{ form_label(resetPasswordForm.plainPassword.second, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                {{ form_widget(resetPasswordForm.plainPassword.second, {attr: {class: 'form-control ft-input', autocomplete: 'new-password', placeholder: 'Repetez votre mot de passe'}}) }}
                {% if resetPasswordForm.plainPassword.second.vars.errors|length > 0 %}
                  <div class="text-danger small mt-1">{{ form_errors(resetPasswordForm.plainPassword.second) }}</div>
                {% endif %}
              </div>

              {% if resetPasswordForm.plainPassword.vars.errors|length > 0 %}
                <div class="text-danger small mb-3">{{ form_errors(resetPasswordForm.plainPassword) }}</div>
              {% endif %}

              <button type="submit" class="btn ft-btn-primary w-100 py-2 fw-semibold">
                <i class="bi bi-key-fill me-2"></i>Mettre a jour mon mot de passe
              </button>
            {{ form_end(resetPasswordForm) }}
          </section>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
