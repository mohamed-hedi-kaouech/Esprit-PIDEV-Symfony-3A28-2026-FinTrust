{% extends 'front/front.html.twig' %}

{% block title %}Mot de passe oublie{% endblock %}

{% block body %}
<div class="ft-auth-page">
  <div class="container">
    <div class="row justify-content-center align-items-center min-vh-100 py-5">
      <div class="col-12 col-lg-10">
        <div class="ft-reset-shell">
          <section class="ft-reset-side">
            <span class="ft-verify-kicker">
              <i class="bi bi-shield-lock"></i> Recuperation securisee
            </span>
            <h1 class="ft-auth-title mb-3">Recuperez l acces a votre compte</h1>
            <p class="ft-verify-copy mb-4">
              FinTrust protege votre espace avec un parcours de reinitialisation par e-mail.
              Si un compte correspond aux informations saisies, vous recevrez un lien securise a usage unique.
            </p>

            <div class="ft-verify-points">
              <article class="ft-verify-point">
                <i class="bi bi-envelope-paper"></i>
                <div>
                  <strong>Lien securise par e-mail</strong>
                  <span>Un lien unique expirant rapidement est envoye si votre compte dispose de cette methode.</span>
                </div>
              </article>
              <article class="ft-verify-point">
                <i class="bi bi-clock-history"></i>
                <div>
                  <strong>Validite courte</strong>
                  <span>Le lien de reinitialisation expire en 15 minutes pour reduire les risques d usage abusif.</span>
                </div>
              </article>
              <article class="ft-verify-point">
                <i class="bi bi-graph-up-arrow"></i>
                <div>
                  <strong>Journalisation de securite</strong>
                  <span>Chaque demande est tracee pour renforcer l audit et la detection d abus.</span>
                </div>
              </article>
            </div>
          </section>

          <section class="ft-auth-card ft-reset-card">
            <div class="text-center mb-4">
              <div class="ft-auth-logo mb-3">
                <svg viewBox="0 0 40 40" fill="none" width="48" height="48">
                  <rect width="40" height="40" rx="10" fill="#1560BD"/>
                  <path d="M10 28V18l10-8 10 8v10H24v-6h-8v6H10Z" fill="white"/>
                </svg>
              </div>
              <h2 class="ft-auth-title ft-verify-title">Mot de passe oublie</h2>
              <p class="text-muted mb-0">Saisissez votre adresse e-mail pour demarrer une recuperation securisee.</p>
            </div>

            {{ form_start(requestForm, {attr: {novalidate: 'novalidate'}}) }}
              <div class="mb-3">
                {{ form_label(requestForm.identifier, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                {{ form_widget(requestForm.identifier, {attr: {class: 'form-control ft-input', placeholder: 'vous@fintrust.tn', autocomplete: 'email'}}) }}
                <div class="form-text">Un lien de reinitialisation sera envoye par e-mail si le compte existe.</div>
                {% if requestForm.identifier.vars.errors|length > 0 %}
                  <div class="text-danger small mt-1">{{ form_errors(requestForm.identifier) }}</div>
                {% endif %}
              </div>

              <button type="submit" class="btn ft-btn-primary w-100 py-2 fw-semibold">
                <i class="bi bi-envelope-check me-2"></i>Envoyer le lien de reinitialisation
              </button>
            {{ form_end(requestForm) }}

            <div class="text-center mt-4">
              <a href="{{ path('app_login') }}" class="small fw-semibold text-decoration-none">Retour a la connexion</a>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
