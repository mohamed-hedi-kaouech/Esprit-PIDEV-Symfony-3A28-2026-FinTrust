<form method="post" action="{{ path('app_categorie_delete', {'id': categorie.idCategorie}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette catégorie ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ categorie.idCategorie) }}">
    <button class="btn">Supprimer</button>
</form>