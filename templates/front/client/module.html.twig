{% extends 'front/front.html.twig' %}

{% block title %}{{ module.title }}{% endblock %}

{% block body %}
<div class="ft-app-page">
  <div class="container-fluid px-4 py-4" style="max-width:1100px">
    <div class="ft-app-card">
      <div class="ft-app-card-body p-5">
        <div class="d-flex align-items-center gap-3 mb-4">
          <div class="ft-page-icon-lg"><i class="bi {{ module.icon }}"></i></div>
          <div>
            <h1 class="ft-page-title mb-1">{{ module.title }}</h1>
            <p class="text-muted mb-0">{{ module.description }}</p>
          </div>
        </div>

        <div class="alert alert-info border-0">
          <i class="bi bi-info-circle me-2"></i>
          Ce module est accessible depuis le header utilisateur. Vous pouvez continuer votre navigation depuis le menu principal.
        </div>

        <div class="d-flex flex-wrap gap-2 mt-4">
          <a href="{{ path('front_dashboard') }}" class="btn ft-btn-primary">
            <i class="bi bi-grid me-2"></i>Retour au dashboard
          </a>
          <a href="{{ path('front_profile') }}" class="btn ft-btn-outline-primary">
            <i class="bi bi-person me-2"></i>Aller au profile
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
