{% block javascripts %}
  {{ parent() }}
  <script>
    (function () {
      const drawer = document.querySelector('[data-ft-assistant-drawer]');
      const openButtons = document.querySelectorAll('[data-ft-assistant-open]');
      const closeButton = document.querySelector('[data-ft-assistant-close]');
      const form = document.querySelector('[data-ft-assistant-form]');
      const input = document.querySelector('[data-ft-assistant-input]');
      const messages = document.querySelector('[data-ft-assistant-messages]');
      const chips = document.querySelectorAll('[data-ft-assistant-question]');

      if (!drawer || !form || !input || !messages) {
        return;
      }

      const responses = [
        {
          match: ['kyc', 'identite', 'verification'],
          answer: "Vous pouvez suivre votre statut KYC dans la section KYC. Si votre dossier est en attente, FinTrust vous notifiera apres verification. Si votre KYC est refuse, vous pouvez soumettre un nouveau dossier avec des justificatifs conformes."
        },
        {
          match: ['profil', 'profile', 'compte', 'informations'],
          answer: "Pour gerer votre profil, ouvrez la section Profile depuis la barre superieure. Vous pouvez y modifier vos informations personnelles, votre langue et votre theme d'affichage."
        },
        {
          match: ['wallet', 'solde', 'transaction', 'transfert'],
          answer: "Le module Wallet permet de consulter vos soldes et vos transactions. S'il est verrouille, cela signifie generalement que votre verification KYC doit etre finalisee avant l'acces complet."
        },
        {
          match: ['budget', 'epargne', 'depense', 'economiser'],
          answer: "Pour mieux gerer votre budget sur FinTrust, suivez vos depenses par categorie, fixez un objectif d'epargne et privilegiez des virements recurrents pour automatiser votre reserve de securite."
        },
        {
          match: ['produit', 'produits', 'recommande', 'offre'],
          answer: "Je peux vous orienter vers les produits FinTrust selon votre besoin. Si vous cherchez la gestion quotidienne, regardez les services de compte et wallet. Pour la planification, explorez les produits lies au budget et a l'epargne."
        },
        {
          match: ['pret', 'loan', 'credit'],
          answer: "La section Loan permet de preparer et suivre vos demandes de pret. L'acceptation d'un pret depend toujours de l'etude de votre dossier, de votre profil et des conditions en vigueur sur la plateforme."
        },
        {
          match: ['notification', 'notifications', 'alerte', 'alertes'],
          answer: "Vos notifications sont visibles dans la section Notifications. Elles centralisent les alertes de securite, l'avancement du KYC et les informations utiles liees a vos services FinTrust."
        },
        {
          match: ['securite', 'risque', 'fraude', 'fraud', 'score'],
          answer: "Pour renforcer la securite de votre compte FinTrust, gardez votre profil a jour, surveillez vos alertes, verifiez votre KYC et consultez regulierement votre score de risque ainsi que vos notifications importantes."
        }
      ];

      const fallback = "Je suis specialise uniquement dans l'assistance FinTrust et les services bancaires de la plateforme. Je peux vous aider sur le profil, le KYC, le wallet, les produits, les prets, le budget, les notifications et la securite du compte.";

      function toggleDrawer(open) {
        drawer.classList.toggle('is-open', open);
        drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
        if (open) {
          setTimeout(() => input.focus(), 120);
        }
      }

      function addMessage(role, content) {
        const article = document.createElement('article');
        article.className = 'ft-assistant-message ' + role;

        const bubble = document.createElement('div');
        bubble.className = 'ft-assistant-bubble';
        bubble.textContent = content;

        article.appendChild(bubble);
        messages.appendChild(article);
        messages.scrollTop = messages.scrollHeight;
      }

      function getResponse(question) {
        const normalized = question.toLowerCase();
        const entry = responses.find((item) => item.match.some((token) => normalized.includes(token)));
        return entry ? entry.answer : fallback;
      }

      function handleQuestion(question) {
        const cleanQuestion = question.trim();
        if (!cleanQuestion) {
          return;
        }

        toggleDrawer(true);
        addMessage('user', cleanQuestion);

        window.setTimeout(() => {
          addMessage('bot', getResponse(cleanQuestion));
        }, 220);
      }

      openButtons.forEach((button) => {
        button.addEventListener('click', () => toggleDrawer(true));
      });

      if (closeButton) {
        closeButton.addEventListener('click', () => toggleDrawer(false));
      }

      drawer.addEventListener('click', (event) => {
        if (event.target === drawer) {
          toggleDrawer(false);
        }
      });

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          handleQuestion(chip.dataset.ftAssistantQuestion || chip.textContent || '');
        });
      });

      form.addEventListener('submit', (event) => {
        event.preventDefault();
        handleQuestion(input.value);
        input.value = '';
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          toggleDrawer(false);
        }
      });
    })();
  </script>
{% endblock %}
