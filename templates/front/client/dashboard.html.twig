{% extends 'front/front.html.twig' %}
{% block title %}Tableau de bord{% endblock %}

{% block body %}
<div class="ft-app-page">
  <div class="container-fluid px-4 py-4">

    <section class="ft-dash-hero mb-4">
      <div class="ft-dash-hero-copy">
        <div class="ft-dash-hero-kicker">
          <i class="bi bi-stars"></i>
          Espace client intelligent
        </div>
        <h1 class="ft-dash-hero-title">
          Bonjour, <span>{{ user.prenom }}</span>
        </h1>
        <p class="ft-dash-hero-subtitle">
          {{ "now"|date("l d F Y") }} ·
          {% if user.kycStatus == 'APPROUVE' %}
            <strong class="text-success-emphasis"><i class="bi bi-patch-check-fill me-1"></i>Compte verifie</strong>
          {% else %}
            <strong class="text-warning-emphasis"><i class="bi bi-exclamation-triangle me-1"></i>KYC en attente</strong>
          {% endif %}
        </p>
        <div class="ft-hero-badge-row">
          <span class="ft-royal-badge ft-royal-badge-{{ user.engagementBadgeTone }}">
            <i class="bi {{ user.engagementBadge == 'ROI FINTRUST' ? 'bi-stars' : (user.engagementBadge == 'ELITE' ? 'bi-gem' : (user.engagementBadge == 'ACTIF+' ? 'bi-lightning-charge-fill' : 'bi-award')) }}"></i>
            {{ user.engagementBadge }}
          </span>
          <span class="ft-hero-badge-note">
            {% if user.engagementBadge == 'ROI FINTRUST' %}
              Client premium a forte activite et forte valeur.
            {% elseif user.engagementBadge == 'ELITE' %}
              Tres bon niveau d'activite et usage regulier des services.
            {% elseif user.engagementBadge == 'ACTIF+' %}
              Client engage avec une activite bancaire soutenue.
            {% else %}
              Badge evolutif qui monte avec votre activite FinTrust.
            {% endif %}
          </span>
        </div>
      </div>

      <div class="ft-dash-hero-side">
        <div class="ft-theme-switcher">
          <form method="post" action="{{ path('front_theme_switch', {mode: 'light'}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('switch_theme') }}">
            <button type="submit" class="ft-theme-pill {{ user.themeMode == 'light' ? 'active' : '' }}">
              <i class="bi bi-sun-fill"></i> Clair
            </button>
          </form>
          <form method="post" action="{{ path('front_theme_switch', {mode: 'dark'}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('switch_theme') }}">
            <button type="submit" class="ft-theme-pill {{ user.themeMode == 'dark' ? 'active' : '' }}">
              <i class="bi bi-moon-stars-fill"></i> Sombre
            </button>
          </form>
        </div>

        <a href="{{ path('front_profile') }}" class="btn ft-btn-outline-primary btn-sm ft-dash-profile-btn">
          <i class="bi bi-person-gear me-1"></i>Profile
        </a>
      </div>
    </section>

    {% if not user.kycApproved %}
      <div class="ft-kyc-banner mb-4">
        <div class="ft-kyc-banner-icon"><i class="bi bi-shield-exclamation"></i></div>
        <div class="flex-grow-1">
          <div class="fw-semibold">Verification d'identite requise</div>
          <div class="small mt-1">
            {% if user.kycStatus == 'EN_ATTENTE' %}
              Votre dossier KYC est <strong>en cours d'examen</strong> par notre equipe. Vous serez notifie des validation.
            {% elseif user.kycStatus == 'REFUSE' %}
              Votre dossier a ete <strong>refuse</strong>. Soumettez un nouveau dossier avec des documents corrects.
            {% else %}
              Deposez vos documents pour debloquer l'acces complet a la plateforme.
            {% endif %}
          </div>
        </div>
        <a href="{{ user.kycStatus == 'EN_ATTENTE' ? path('front_kyc_status') : path('front_kyc_submit') }}" class="btn ft-btn-primary btn-sm text-nowrap">
          {% if user.kycStatus == 'EN_ATTENTE' %}
            <i class="bi bi-clock me-1"></i>Voir le statut
          {% else %}
            <i class="bi bi-upload me-1"></i>Deposer mon KYC
          {% endif %}
        </a>
      </div>
    {% endif %}

    {% if user.riskLevel in ['HIGH', 'CRITICAL'] %}
      <div class="ft-kyc-banner mb-4 {{ user.riskLevel == 'CRITICAL' ? 'ft-risk-banner-critical' : 'ft-risk-banner-high' }}">
        <div class="ft-kyc-banner-icon"><i class="bi bi-radar"></i></div>
        <div class="flex-grow-1">
          <div class="fw-semibold">Surveillance renforcée du compte</div>
          <div class="small mt-1">
            Risk level: <strong>{{ user.riskLevel }}</strong> · Fraud score: <strong>{{ user.fraudScore|number_format(1, ',', ' ') }}/100</strong>.
            {% if user.riskLevel == 'CRITICAL' %}
              Certaines actions sensibles sont temporairement restreintes pour protéger votre compte.
            {% else %}
              Une vigilance supplémentaire est activée sur vos opérations sensibles.
            {% endif %}
          </div>
        </div>
        <a href="{{ path('front_notifications') }}" class="btn ft-btn-primary btn-sm text-nowrap">
          <i class="bi bi-bell me-1"></i>Voir les alertes
        </a>
      </div>
    {% endif %}

    <div class="row g-3 mb-4">
      <div class="col-6 col-lg-3">
        <div class="ft-dash-card ft-dash-card-accent ft-dash-card-status">
          <div class="ft-dash-card-icon ft-dash-icon-blue"><i class="bi bi-person-check-fill"></i></div>
          <div class="ft-dash-card-label">Statut compte</div>
          <div class="ft-dash-card-value">
            {% if user.status == 'ACTIF' %}<span class="badge ft-badge-success">Actif</span>
            {% elseif user.status == 'EN_ATTENTE' %}<span class="badge ft-badge-warning">En attente</span>
            {% else %}<span class="badge ft-badge-danger">Suspendu</span>{% endif %}
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="ft-dash-card ft-dash-card-accent ft-dash-card-kyc">
          <div class="ft-dash-card-icon ft-dash-icon-green"><i class="bi bi-shield-check-fill"></i></div>
          <div class="ft-dash-card-label">Statut KYC</div>
          <div class="ft-dash-card-value">
            {% if user.kycStatus == 'APPROUVE' %}<span class="badge ft-badge-success">Approuve</span>
            {% elseif user.kycStatus == 'EN_ATTENTE' %}<span class="badge ft-badge-warning">En attente</span>
            {% elseif user.kycStatus == 'REFUSE' %}<span class="badge ft-badge-danger">Refuse</span>
            {% else %}<span class="badge ft-badge-neutral">Non soumis</span>{% endif %}
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="ft-dash-card ft-dash-card-accent ft-dash-card-member">
          <div class="ft-dash-card-icon ft-dash-icon-purple"><i class="bi bi-calendar-check-fill"></i></div>
          <div class="ft-dash-card-label">Membre depuis</div>
          <div class="ft-dash-card-value fw-semibold small">{{ user.createdAt|date('d/m/Y') }}</div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="ft-dash-card ft-dash-card-accent ft-dash-card-role">
          <div class="ft-dash-card-icon ft-dash-icon-orange"><i class="bi bi-award-fill"></i></div>
          <div class="ft-dash-card-label">Role</div>
          <div class="ft-dash-card-value"><span class="badge ft-badge-blue">{{ user.role }}</span></div>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-6 col-xl-3">
        <div class="ft-dash-card ft-dash-card-soft">
          <div class="ft-dash-card-icon ft-dash-icon-blue"><i class="bi bi-translate"></i></div>
          <div class="ft-dash-card-label">Langue</div>
          <div class="ft-dash-card-value">{{ user.preferredLanguage|upper }}</div>
        </div>
      </div>
      <div class="col-md-6 col-xl-3">
        <div class="ft-dash-card ft-dash-card-soft">
          <div class="ft-dash-card-icon ft-dash-icon-purple"><i class="bi bi-circle-half"></i></div>
          <div class="ft-dash-card-label">Theme</div>
          <div class="ft-dash-card-value">{{ user.themeMode == 'dark' ? 'Sombre' : 'Clair' }}</div>
        </div>
      </div>
      <div class="col-md-6 col-xl-3">
        <div class="ft-dash-card ft-dash-card-soft">
          <div class="ft-dash-card-icon ft-dash-icon-green"><i class="bi bi-arrow-left-right"></i></div>
          <div class="ft-dash-card-label">Frequence transactions</div>
          <div class="ft-dash-card-value">{{ user.transactionFrequency|number_format(2, ',', ' ') }}/jour</div>
        </div>
      </div>
      <div class="col-md-6 col-xl-3">
        <div class="ft-dash-card ft-dash-card-soft">
          <div class="ft-dash-card-icon ft-dash-icon-orange"><i class="bi bi-activity"></i></div>
          <div class="ft-dash-card-label">Score de risque</div>
          <div class="ft-dash-card-value">{{ user.riskScore|number_format(1, ',', ' ') }}/100 · {{ user.riskLevel }}</div>
        </div>
      </div>
      <div class="col-md-6 col-xl-3">
        <div class="ft-dash-card ft-dash-card-soft">
          <div class="ft-dash-card-icon ft-dash-icon-red"><i class="bi bi-shield-fill-exclamation"></i></div>
          <div class="ft-dash-card-label">Fraud score</div>
          <div class="ft-dash-card-value">{{ user.fraudScore|number_format(1, ',', ' ') }}/100</div>
        </div>
      </div>
    </div>

    <div class="ft-app-card mb-4 ft-insight-panel">
      <div class="ft-app-card-header">
        <i class="bi bi-cpu me-2 text-primary"></i>Profil intelligent FinTrust
      </div>
      <div class="ft-app-card-body">
        <div class="row g-3">
          <div class="col-md-4">
            <div class="ft-action-card h-100">
              <div class="ft-action-icon"><i class="bi bi-cash-coin"></i></div>
              <div>
                <div class="ft-module-title">Montant moyen</div>
                <div class="ft-module-desc">{{ user.averageTransactionAmount|number_format(2, ',', ' ') }} TND</div>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="ft-action-card h-100">
              <div class="ft-action-icon"><i class="bi bi-diagram-3"></i></div>
              <div>
                <div class="ft-module-title">Segment automatique</div>
                <div class="ft-module-desc">{{ user.clientSegment == 'A_RISQUE' ? 'A risque' : user.clientSegment }}</div>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="ft-action-card h-100">
              <div class="ft-action-icon"><i class="bi bi-clock-history"></i></div>
              <div>
                <div class="ft-module-title">Score evolutif</div>
                <div class="ft-module-desc">Mis a jour {{ user.behaviorUpdatedAt ? user.behaviorUpdatedAt|date('d/m/Y H:i') : 'automatiquement' }}</div>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="ft-action-card h-100">
              <div class="ft-action-icon"><i class="bi bi-patch-check"></i></div>
              <div>
                <div class="ft-module-title">Badge de prestige</div>
                <div class="ft-module-desc">
                  <span class="ft-royal-badge ft-royal-badge-{{ user.engagementBadgeTone }}">
                    <i class="bi {{ user.engagementBadge == 'ROI FINTRUST' ? 'bi-stars' : (user.engagementBadge == 'ELITE' ? 'bi-gem' : (user.engagementBadge == 'ACTIF+' ? 'bi-lightning-charge-fill' : 'bi-award')) }}"></i>
                    {{ user.engagementBadge }}
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-12 col-xl-8">
        <div class="ft-app-card ft-premium-card h-100">
          <div class="ft-app-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span><i class="bi bi-wallet2 me-2 text-primary"></i>Resume financier</span>
            <span class="badge ft-badge-blue">Vue globale</span>
          </div>
          <div class="ft-app-card-body">
            <div class="row g-3 mb-3">
              <div class="col-md-4">
                <div class="ft-finance-metric">
                  <span class="ft-finance-label">Capacite mensuelle</span>
                  <strong>{{ (user.averageTransactionAmount * 4)|number_format(2, ',', ' ') }} TND</strong>
                  <small>Projection basee sur votre activite moyenne</small>
                </div>
              </div>
              <div class="col-md-4">
                <div class="ft-finance-metric ft-finance-metric-soft">
                  <span class="ft-finance-label">Epargne disponible</span>
                  <strong>{{ (user.averageTransactionAmount * 1.8)|number_format(2, ',', ' ') }} TND</strong>
                  <small>Reserve recommandee sur 30 jours</small>
                </div>
              </div>
              <div class="col-md-4">
                <div class="ft-finance-metric ft-finance-metric-accent">
                  <span class="ft-finance-label">Niveau de confort</span>
                  <strong>{{ user.clientSegment == 'VIP' ? 'Premium' : (user.clientSegment == 'A_RISQUE' ? 'Sous surveillance' : 'Stable') }}</strong>
                  <small>Ajuste selon votre profil intelligent</small>
                </div>
              </div>
            </div>

            <div class="ft-mini-chart">
              <div class="ft-mini-chart-header">
                <span>Evolution des flux</span>
                <span class="text-muted small">7 derniers jours</span>
              </div>
              <div class="ft-bars">
                <div class="ft-bar-wrap"><span class="ft-bar" style="height: 48%"></span><small>L</small></div>
                <div class="ft-bar-wrap"><span class="ft-bar" style="height: 72%"></span><small>M</small></div>
                <div class="ft-bar-wrap"><span class="ft-bar" style="height: 58%"></span><small>M</small></div>
                <div class="ft-bar-wrap"><span class="ft-bar" style="height: 84%"></span><small>J</small></div>
                <div class="ft-bar-wrap"><span class="ft-bar" style="height: 66%"></span><small>V</small></div>
                <div class="ft-bar-wrap"><span class="ft-bar" style="height: 92%"></span><small>S</small></div>
                <div class="ft-bar-wrap"><span class="ft-bar" style="height: 56%"></span><small>D</small></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-4">
        <div class="ft-app-card ft-premium-card h-100">
          <div class="ft-app-card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-shield-lock me-2 text-primary"></i>Alertes de securite</span>
            <span class="badge {{ user.riskLevel in ['HIGH', 'CRITICAL'] ? 'ft-badge-danger' : 'ft-badge-success' }}">
              {{ user.riskLevel }}
            </span>
          </div>
          <div class="ft-app-card-body">
            <div class="ft-security-alert {{ user.riskLevel == 'CRITICAL' ? 'danger' : (user.riskLevel == 'HIGH' ? 'warning' : 'safe') }}">
              <div class="ft-security-icon"><i class="bi bi-radar"></i></div>
              <div>
                <strong>Score de fraude: {{ user.fraudScore|number_format(1, ',', ' ') }}/100</strong>
                <p class="mb-0">
                  {% if user.riskLevel == 'CRITICAL' %}
                    Un renforcement temporaire protege vos operations sensibles.
                  {% elseif user.riskLevel == 'HIGH' %}
                    Une verification supplementaire peut etre demandee sur certaines actions.
                  {% else %}
                    Aucun signal critique detecte. Votre compte reste dans une zone saine.
                  {% endif %}
                </p>
              </div>
            </div>

            <div class="ft-simple-list mt-3">
              <div class="ft-simple-item">
                <i class="bi bi-fingerprint"></i>
                <span>Authentification securisee activee</span>
              </div>
              <div class="ft-simple-item">
                <i class="bi bi-bell"></i>
                <span>Notifications intelligentes en temps reel</span>
              </div>
              <div class="ft-simple-item">
                <i class="bi bi-clock-history"></i>
                <span>Derniere analyse comportementale:
                  {{ user.behaviorUpdatedAt ? user.behaviorUpdatedAt|date('d/m H:i') : 'a l instant' }}
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-12 col-lg-7">
        <div class="ft-app-card ft-premium-card h-100">
          <div class="ft-app-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span><i class="bi bi-activity me-2 text-primary"></i>Activite recente</span>
            <a href="{{ path('front_notifications') }}" class="ft-inline-link">Voir tout</a>
          </div>
          <div class="ft-app-card-body">
            <div class="ft-timeline">
              <div class="ft-timeline-item">
                <div class="ft-timeline-dot success"></div>
                <div>
                  <strong>Verification KYC {{ user.kycApproved ? 'confirmee' : 'en cours' }}</strong>
                  <p class="mb-0">Votre dossier identite suit son cycle de validation intelligent.</p>
                </div>
                <span>{{ user.createdAt|date('d/m') }}</span>
              </div>
              <div class="ft-timeline-item">
                <div class="ft-timeline-dot info"></div>
                <div>
                  <strong>Profil mis a jour</strong>
                  <p class="mb-0">Langue {{ user.preferredLanguage|upper }} et theme {{ user.themeMode == 'dark' ? 'sombre' : 'clair' }} synchronises.</p>
                </div>
                <span>Aujourd'hui</span>
              </div>
              <div class="ft-timeline-item">
                <div class="ft-timeline-dot warning"></div>
                <div>
                  <strong>Analyse de risque recalculée</strong>
                  <p class="mb-0">Score actuel {{ user.riskScore|number_format(1, ',', ' ') }}/100 avec segment {{ user.clientSegment == 'A_RISQUE' ? 'a risque' : user.clientSegment|lower }}.</p>
                </div>
                <span>{{ user.behaviorUpdatedAt ? user.behaviorUpdatedAt|date('H:i') : 'Maintenant' }}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-5">
        <div class="ft-app-card ft-premium-card h-100">
          <div class="ft-app-card-header">
            <i class="bi bi-lightbulb me-2 text-primary"></i>Recommandations personnalisees
          </div>
          <div class="ft-app-card-body">
            <div class="ft-reco-card">
              <span class="badge ft-badge-success">Conseil intelligent</span>
              <h3>Optimisez votre coussin de securite</h3>
              <p>FinTrust recommande de conserver l'equivalent de 3 semaines de depenses pour lisser vos operations sensibles.</p>
              <div class="ft-progress-row">
                <div class="ft-progress-track">
                  <span style="width: 68%"></span>
                </div>
                <small>68% de l'objectif ideal</small>
              </div>
            </div>

            <div class="ft-reco-list mt-3">
              <div class="ft-reco-item">
                <i class="bi bi-graph-up-arrow"></i>
                <span>Activez un produit d'epargne automatique pour valoriser votre profil {{ user.clientSegment|lower }}.</span>
              </div>
              <div class="ft-reco-item">
                <i class="bi bi-stars"></i>
                <span>Votre compte est compatible avec des experiences premium plus personnalisees.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-12 col-xl-4">
        <div class="ft-app-card ft-premium-card h-100">
          <div class="ft-app-card-header">
            <i class="bi bi-piggy-bank me-2 text-primary"></i>Objectifs d'epargne
          </div>
          <div class="ft-app-card-body">
            <div class="ft-goal-card">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <strong>Fonds de securite</strong>
                <span class="badge ft-badge-blue">Prioritaire</span>
              </div>
              <div class="ft-progress-track mb-2">
                <span style="width: 54%"></span>
              </div>
              <div class="d-flex justify-content-between text-muted small">
                <span>540 TND</span>
                <span>Objectif 1 000 TND</span>
              </div>
            </div>

            <div class="ft-goal-card">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <strong>Projet personnel</strong>
                <span class="badge ft-badge-success">En bonne voie</span>
              </div>
              <div class="ft-progress-track mb-2 ft-progress-soft">
                <span style="width: 77%"></span>
              </div>
              <div class="d-flex justify-content-between text-muted small">
                <span>1 540 TND</span>
                <span>Objectif 2 000 TND</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-4">
        <div class="ft-app-card ft-premium-card h-100">
          <div class="ft-app-card-header">
            <i class="bi bi-pie-chart me-2 text-primary"></i>Statistiques de depenses
          </div>
          <div class="ft-app-card-body">
            <div class="ft-spend-ring">
              <div class="ft-spend-ring-inner">
                <strong>72%</strong>
                <span>budget maitrise</span>
              </div>
            </div>

            <div class="ft-category-list mt-3">
              <div class="ft-category-item">
                <span><i class="bi bi-house-door"></i>Habitation</span>
                <strong>38%</strong>
              </div>
              <div class="ft-category-item">
                <span><i class="bi bi-bag"></i>Achats</span>
                <strong>24%</strong>
              </div>
              <div class="ft-category-item">
                <span><i class="bi bi-car-front"></i>Transport</span>
                <strong>18%</strong>
              </div>
              <div class="ft-category-item">
                <span><i class="bi bi-heart-pulse"></i>Sante</span>
                <strong>12%</strong>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-4">
        <div class="ft-app-card ft-premium-card h-100">
          <div class="ft-app-card-header">
            <i class="bi bi-grid me-2 text-primary"></i>Raccourcis rapides
          </div>
          <div class="ft-app-card-body">
            <div class="ft-shortcuts-grid">
              <a href="{{ path('front_profile') }}" class="ft-shortcut-tile">
                <i class="bi bi-person-circle"></i>
                <span>Profil</span>
              </a>
              <a href="{{ path('front_notifications') }}" class="ft-shortcut-tile">
                <i class="bi bi-bell"></i>
                <span>Alertes</span>
              </a>
              <a href="{{ user.kycStatus in ['EN_ATTENTE', 'APPROUVE'] ? path('front_kyc_status') : path('front_kyc_submit') }}" class="ft-shortcut-tile">
                <i class="bi bi-shield-check"></i>
                <span>KYC</span>
              </a>
              <a href="{{ path('front_module', {slug: 'publications'}) }}" class="ft-shortcut-tile">
                <i class="bi bi-journal-richtext"></i>
                <span>Insights</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-12 col-xl-5">
        <div class="ft-app-card ft-premium-card h-100">
