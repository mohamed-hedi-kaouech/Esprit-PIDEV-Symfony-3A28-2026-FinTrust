{% extends 'front/front.html.twig' %}
{% block title %}Mes transactions{% endblock %}

{% block body %}
<div class="ft-app-page">
  <div class="container-fluid px-4 py-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
      <div class="d-flex align-items-center gap-3">
        <div class="ft-page-icon-lg"><i class="bi bi-arrow-left-right"></i></div>
        <div>
          <h1 class="ft-page-title mb-0">Historique des transactions</h1>
          <p class="text-muted mb-0 small">Retrouvez toutes les operations liees a votre wallet.</p>
        </div>
      </div>
      <div class="d-flex flex-wrap gap-2">
        <a href="{{ path('front_wallet_transaction_new') }}" class="btn ft-btn-primary">
          <i class="bi bi-plus-circle me-1"></i>Effectuer une transaction
        </a>
        <a href="{{ path('front_wallet_dashboard') }}" class="btn ft-btn-outline-primary">
          <i class="bi bi-house-door me-1"></i>Dashboard
        </a>
        <a href="{{ path('front_wallet_show') }}" class="btn ft-btn-outline-primary">
          <i class="bi bi-eye me-1"></i>Detail wallet
        </a>
      </div>
    </div>

    <div class="ft-app-card ft-premium-card mb-4">
      <div class="ft-app-card-header">
        <i class="bi bi-funnel me-2 text-primary"></i>Filtres
      </div>
      <div class="ft-app-card-body">
        <form method="get" class="row g-3 align-items-end">
          <div class="col-md-3">
            <label class="form-label fw-semibold small">Type</label>
            <select name="type" class="form-select ft-input">
              <option value="">Tous</option>
              <option value="depot" {{ filters.type == 'depot' ? 'selected' }}>Depot</option>
              <option value="retrait" {{ filters.type == 'retrait' ? 'selected' }}>Retrait</option>
              <option value="transfert" {{ filters.type == 'transfert' ? 'selected' }}>Transfert</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold small">Du</label>
            <input type="date" name="date_from" value="{{ filters.date_from }}" class="form-control ft-input">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold small">Au</label>
            <input type="date" name="date_to" value="{{ filters.date_to }}" class="form-control ft-input">
          </div>
          <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn ft-btn-primary flex-grow-1">
              <i class="bi bi-search me-1"></i>Filtrer
            </button>
            <a href="{{ path('front_wallet_transactions') }}" class="btn ft-btn-outline-primary">
              <i class="bi bi-arrow-counterclockwise"></i>
            </a>
          </div>
        </form>
      </div>
    </div>

    <div class="ft-app-card ft-premium-card">
      <div class="ft-app-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="bi bi-list-ul me-2 text-primary"></i>Liste des transactions</span>
        <span class="badge ft-badge-blue">{{ pagination.total }} transaction{{ pagination.total > 1 ? 's' }}</span>
      </div>
      <div class="ft-app-card-body p-0">
        {% if transactions is empty %}
          <div class="p-4 text-muted">Aucune transaction ne correspond a vos filtres.</div>
        {% else %}
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>ID</th>
                  <th>Montant</th>
                  <th>Type</th>
                  <th>Description</th>
                  <th>Date transaction</th>
                </tr>
              </thead>
              <tbody>
                {% for transaction in transactions %}
                  {% set type = transaction.type|lower %}
                  <tr>
                    <td class="fw-semibold">#{{ transaction.idTransaction }}</td>
                    <td>{{ transaction.montant|number_format(2, ',', ' ') }} {{ wallet.devise }}</td>
                    <td>
                      <span class="badge {{ type == 'depot' ? 'ft-badge-success' : (type == 'retrait' ? 'ft-badge-warning' : 'ft-badge-blue') }}">
                        {{ transaction.type|title }}
                      </span>
                    </td>
                    <td>{{ transaction.description ?: 'Sans description' }}</td>
                    <td>{{ transaction.dateTransaction|date('d/m/Y H:i') }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </div>

      {% if pagination.pages > 1 %}
        <div class="ft-app-card-body border-top">
          <nav aria-label="Pagination transactions">
            <ul class="pagination justify-content-center mb-0">
              {% for p in 1..pagination.pages %}
                <li class="page-item {{ p == pagination.page ? 'active' }}">
                  <a class="page-link" href="{{ path('front_wallet_transactions', {page: p, type: filters.type, date_from: filters.date_from, date_to: filters.date_to}) }}">{{ p }}</a>
                </li>
              {% endfor %}
            </ul>
          </nav>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
