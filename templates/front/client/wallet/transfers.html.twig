{% extends 'front/front.html.twig' %}
{% block title %}Historique des transferts{% endblock %}

{% block body %}
<div class="ft-app-page">
  <div class="container-fluid px-4 py-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
      <div class="d-flex align-items-center gap-3">
        <div class="ft-page-icon-lg"><i class="bi bi-arrow-left-right"></i></div>
        <div>
          <h1 class="ft-page-title mb-0">Historique avance des transferts</h1>
          <p class="text-muted mb-0 small">Recherchez vos envois et receptions par reference, statut, periode ou contrepartie.</p>
        </div>
      </div>
      <div class="d-flex flex-wrap gap-2">
        <a href="{{ path('front_wallet_transfer_new') }}" class="btn ft-btn-primary">
          <i class="bi bi-send-plus me-1"></i>Nouveau transfert
        </a>
        <a href="{{ path('front_wallet_transfer_export_csv', filters) }}" class="btn ft-btn-outline-primary">
          <i class="bi bi-filetype-csv me-1"></i>CSV
        </a>
        <a href="{{ path('front_wallet_transfer_export_pdf', filters) }}" class="btn ft-btn-outline-primary">
          <i class="bi bi-file-earmark-pdf me-1"></i>PDF
        </a>
      </div>
    </div>

    <div class="ft-app-card ft-premium-card mb-4">
      <div class="ft-app-card-header">
        <i class="bi bi-funnel me-2 text-primary"></i>Filtres avances
      </div>
      <div class="ft-app-card-body">
        <form method="get" class="row g-3 align-items-end">
          <div class="col-md-3">
            <label class="form-label fw-semibold small">Sens</label>
            <select name="direction" class="form-select ft-input">
              <option value="all" {{ filters.direction == 'all' ? 'selected' }}>Tous</option>
              <option value="sent" {{ filters.direction == 'sent' ? 'selected' }}>Envoyes</option>
              <option value="received" {{ filters.direction == 'received' ? 'selected' }}>Recus</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold small">Recherche</label>
            <input type="text" name="query" value="{{ filters.query }}" class="form-control ft-input" placeholder="Reference, nom, libelle...">
          </div>
          <div class="col-md-2">
            <label class="form-label fw-semibold small">Statut</label>
            <select name="status" class="form-select ft-input">
              <option value="">Tous</option>
              <option value="VALIDE" {{ filters.status == 'VALIDE' ? 'selected' }}>Valide</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label fw-semibold small">Du</label>
            <input type="date" name="date_from" value="{{ filters.date_from }}" class="form-control ft-input">
          </div>
          <div class="col-md-2">
            <label class="form-label fw-semibold small">Au</label>
            <input type="date" name="date_to" value="{{ filters.date_to }}" class="form-control ft-input">
          </div>
          <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn ft-btn-primary">
              <i class="bi bi-search me-1"></i>Filtrer
            </button>
            <a href="{{ path('front_wallet_transfer_history') }}" class="btn ft-btn-outline-primary">
              <i class="bi bi-arrow-counterclockwise"></i>
            </a>
          </div>
        </form>
      </div>
    </div>

    <div class="ft-app-card ft-premium-card">
      <div class="ft-app-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-list-ul me-2 text-primary"></i>Liste des transferts</span>
        <span class="badge ft-badge-blue">{{ transfers|length }} resultat{{ transfers|length > 1 ? 's' }}</span>
      </div>
      <div class="ft-app-card-body p-0">
        {% if transfers is empty %}
          <div class="p-4 text-muted">Aucun transfert ne correspond aux filtres selectionnes.</div>
        {% else %}
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Reference</th>
                  <th>Sens</th>
                  <th>Statut</th>
                  <th>Montant</th>
                  <th>Contrepartie</th>
                  <th>Libelle</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                {% for transfer in transfers %}
                  <tr>
                    <td class="fw-semibold">{{ transfer.reference }}</td>
                    <td>
                      <span class="badge {{ transfer.direction == 'received' ? 'ft-badge-success' : 'ft-badge-warning' }}">
                        {{ transfer.direction == 'received' ? 'Recu' : 'Envoye' }}
                      </span>
                    </td>
                    <td><span class="badge ft-badge-blue">{{ transfer.status }}</span></td>
                    <td>{{ transfer.amount|number_format(2, ',', ' ') }} {{ wallet.devise }}</td>
                    <td>{{ transfer.counterparty }}</td>
                    <td>{{ transfer.label ?: '-' }}</td>
                    <td>{{ transfer.date|date('d/m/Y H:i') }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
