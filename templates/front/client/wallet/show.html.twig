{% extends 'front/front.html.twig' %}
{% block title %}Detail wallet{% endblock %}

{% block body %}
<div class="ft-app-page">
  <div class="container-fluid px-4 py-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
      <div class="d-flex align-items-center gap-3">
        <div class="ft-page-icon-lg"><i class="bi bi-credit-card"></i></div>
        <div>
          <h1 class="ft-page-title mb-0">Detail de mon wallet</h1>
          <p class="text-muted mb-0 small">Toutes les informations du wallet et les operations rattachees.</p>
        </div>
      </div>
      <div class="d-flex flex-wrap gap-2">
        <a href="{{ path('front_wallet_dashboard') }}" class="btn ft-btn-outline-primary">
          <i class="bi bi-house-door me-1"></i>Dashboard
        </a>
        <a href="{{ path('front_wallet_transactions') }}" class="btn ft-btn-outline-primary">
          <i class="bi bi-arrow-left-right me-1"></i>Transactions
        </a>
        <a href="{{ path('front_wallet_cheques') }}" class="btn ft-btn-outline-primary">
          <i class="bi bi-journal-text me-1"></i>Cheques
        </a>
      </div>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-xl-5">
        <div class="ft-app-card ft-premium-card h-100">
          <div class="ft-app-card-header">
            <i class="bi bi-info-circle me-2 text-primary"></i>Informations wallet
          </div>
          <div class="ft-app-card-body p-0">
            <ul class="list-group list-group-flush">
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">ID wallet</span>
                <span class="fw-semibold">#{{ wallet.idWallet }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Nom proprietaire</span>
                <span class="fw-semibold">{{ wallet.nomProprietaire }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Email</span>
                <span class="fw-semibold">{{ wallet.email ?: 'Non renseigne' }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Telephone</span>
                <span class="fw-semibold">{{ wallet.telephone ?: 'Non renseigne' }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Solde</span>
                <span class="fw-semibold">{{ wallet.solde|number_format(2, ',', ' ') }} {{ wallet.devise }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Devise</span>
                <span class="badge ft-badge-blue">{{ wallet.devise }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Statut</span>
                <span class="badge {{ wallet.estBloque ? 'ft-badge-danger' : (wallet.estActif ? 'ft-badge-success' : 'ft-badge-warning') }}">
                  {{ wallet.statut|title }}
                </span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Actif</span>
                <span class="badge {{ wallet.estActif ? 'ft-badge-success' : 'ft-badge-neutral' }}">{{ wallet.estActif ? 'Oui' : 'Non' }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Bloque</span>
                <span class="badge {{ wallet.estBloque ? 'ft-badge-danger' : 'ft-badge-success' }}">{{ wallet.estBloque ? 'Oui' : 'Non' }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Date creation</span>
                <span class="fw-semibold">{{ wallet.dateCreation|date('d/m/Y H:i') }}</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-xl-7">
        <div class="row g-3">
          <div class="col-md-6">
            <div class="ft-dash-card ft-dash-card-soft h-100">
              <div class="ft-dash-card-icon ft-dash-icon-blue"><i class="bi bi-arrow-left-right"></i></div>
              <div class="ft-dash-card-label">Transactions liees</div>
              <div class="ft-dash-card-value">{{ transactionCount }}</div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="ft-dash-card ft-dash-card-soft h-100">
              <div class="ft-dash-card-icon ft-dash-icon-green"><i class="bi bi-journal-check"></i></div>
              <div class="ft-dash-card-label">Cheques lies</div>
              <div class="ft-dash-card-value">{{ chequeCount }}</div>
            </div>
          </div>
          <div class="col-12">
            <div class="ft-app-card ft-premium-card h-100">
              <div class="ft-app-card-header">
                <i class="bi bi-stars me-2 text-primary"></i>Lecture rapide
              </div>
              <div class="ft-app-card-body">
                <div class="row g-3">
                  <div class="col-md-4">
                    <div class="ft-finance-metric">
                      <span class="ft-finance-label">Disponibilite</span>
                      <strong>{{ wallet.estActif and not wallet.estBloque ? 'Disponible' : 'Limitee' }}</strong>
                      <small>Usage bancaire courant</small>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="ft-finance-metric ft-finance-metric-soft">
                      <span class="ft-finance-label">Chequier</span>
                      <strong>{{ wallet.estBloque ? 'Suspendu' : 'Autorise' }}</strong>
                      <small>Selon l etat du wallet</small>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="ft-finance-metric ft-finance-metric-accent">
                      <span class="ft-finance-label">Devise active</span>
                      <strong>{{ wallet.devise }}</strong>
                      <small>Compte bancaire principal</small>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-xl-7">
        <div class="ft-app-card ft-premium-card h-100">
          <div class="ft-app-card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-clock-history me-2 text-primary"></i>Transactions du wallet</span>
            <a href="{{ path('front_wallet_transactions') }}" class="ft-inline-link">Historique complet</a>
          </div>
          <div class="ft-app-card-body p-0">
            {% if transactions is empty %}
              <div class="p-4 text-muted">Aucune transaction liee a ce wallet.</div>
            {% else %}
              <div class="table-responsive">
                <table class="table align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>ID</th>
                      <th>Montant</th>
                      <th>Type</th>
                      <th>Description</th>
                      <th>Date</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for transaction in transactions %}
                      {% set type = transaction.type|lower %}
                      <tr>
                        <td class="fw-semibold">#{{ transaction.idTransaction }}</td>
                        <td>{{ transaction.montant|number_format(2, ',', ' ') }} {{ wallet.devise }}</td>
                        <td>
                          <span class="badge {{ type == 'depot' ? 'ft-badge-success' : (type == 'retrait' ? 'ft-badge-warning' : 'ft-badge-blue') }}">
                            {{ transaction.type|title }}
                          </span>
                        </td>
                        <td>{{ transaction.description ?: 'Sans description' }}</td>
                        <td>{{ transaction.dateTransaction|date('d/m/Y H:i') }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="col-xl-5">
        <div class="ft-app-card ft-premium-card mb-4">
          <div class="ft-app-card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-bell me-2 text-primary"></i>Notifications de transfert</span>
            <a href="{{ path('front_notifications') }}" class="ft-inline-link">Centre complet</a>
          </div>
          <div class="ft-app-card-body p-0">
            {% if transferNotifications is empty %}
              <div class="p-4 text-muted">Aucune notification de transfert disponible.</div>
            {% else %}
              <div class="list-group list-group-flush">
                {% for notification in transferNotifications %}
                  <div class="list-group-item px-4 py-3">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                      <div>
                        <div class="fw-semibold mb-1">Transfert recu</div>
                        <div class="text-muted small">{{ notification.message }}</div>
                      </div>
                      <div class="text-end">
                        <span class="badge {{ notification.read ? 'ft-badge-neutral' : 'ft-badge-success' }}">
                          {{ notification.read ? 'Lue' : 'Non lue' }}
                        </span>
                        <div class="text-muted small mt-2">{{ notification.createdAt|date('d/m/Y H:i') }}</div>
                      </div>
                    </div>
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>
          {% if transferNotificationCount > 0 %}
            <div class="ft-app-card-body border-top py-3">
              <span class="badge ft-badge-blue">{{ transferNotificationCount }} non lue{{ transferNotificationCount > 1 ? 's' : '' }}</span>
            </div>
          {% endif %}
        </div>

        <div class="ft-app-card ft-premium-card h-100">
          <div class="ft-app-card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-journal-check me-2 text-primary"></i>Cheques lies</span>
            <a href="{{ path('front_wallet_cheques') }}" class="ft-inline-link">Mes demandes</a>
          </div>
          <div class="ft-app-card-body p-0">
            {% if cheques is empty %}
              <div class="p-4 text-muted">Aucune demande de cheque pour ce wallet.</div>
            {% else %}
              <div class="table-responsive">
                <table class="table align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>Numero</th>
                      <th>Beneficiaire</th>
                      <th>Montant</th>
                      <th>Statut</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for cheque in cheques %}
                      {% set statut = cheque.statut|lower %}
                      <tr>
                        <td class="fw-semibold">{{ cheque.numeroCheque }}</td>
                        <td>{{ cheque.beneficiaire ?: 'Non renseigne' }}</td>
                        <td>{{ cheque.montant|number_format(2, ',', ' ') }} {{ wallet.devise }}</td>
                        <td>
                          <span class="badge {{ statut == 'accepte' ? 'ft-badge-success' : (statut == 'refuse' ? 'ft-badge-danger' : 'ft-badge-warning') }}">
                            {{ cheque.statut|replace({'_': ' '})|title }}
                          </span>
                        </td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
