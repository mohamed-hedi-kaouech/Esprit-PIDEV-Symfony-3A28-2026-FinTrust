{% extends 'front/front.html.twig' %}
{% block title %}Nouvelle transaction{% endblock %}

{% block body %}
<div class="ft-app-page">
  <div class="container-fluid px-4 py-4" style="max-width:1100px">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
      <div class="d-flex align-items-center gap-3">
        <div class="ft-page-icon-lg"><i class="bi bi-cash-coin"></i></div>
        <div>
          <h1 class="ft-page-title mb-0">Effectuer une transaction</h1>
          <p class="text-muted mb-0 small">Enregistrez un depot ou un retrait sur votre wallet.</p>
        </div>
      </div>
      <div class="d-flex flex-wrap gap-2">
        <a href="{{ path('front_wallet_transactions') }}" class="btn ft-btn-outline-primary">
          <i class="bi bi-arrow-left-right me-1"></i>Transactions
        </a>
        <a href="{{ path('front_wallet_dashboard') }}" class="btn ft-btn-outline-primary">
          <i class="bi bi-house-door me-1"></i>Dashboard
        </a>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-lg-7">
        <div class="ft-app-card ft-premium-card">
          <div class="ft-app-card-header">
            <i class="bi bi-pencil-square me-2 text-primary"></i>Formulaire de transaction
          </div>
          <div class="ft-app-card-body">
            {{ form_start(form) }}
              <div class="row g-3">
                <div class="col-md-6">
                  {{ form_label(form.type, null, {label_attr: {class: 'form-label fw-semibold small'}}) }}
                  {{ form_widget(form.type, {attr: {class: 'form-select ft-input'}}) }}
                  {% if form.type.vars.errors|length > 0 %}
                    <div class="text-danger small mt-1">{{ form_errors(form.type) }}</div>
                  {% endif %}
                </div>
                <div class="col-md-6">
                  {{ form_label(form.montant, null, {label_attr: {class: 'form-label fw-semibold small'}}) }}
                  {{ form_widget(form.montant, {attr: {class: 'form-control ft-input'}}) }}
                  {% if form.montant.vars.errors|length > 0 %}
                    <div class="text-danger small mt-1">{{ form_errors(form.montant) }}</div>
                  {% endif %}
                </div>
                <div class="col-12">
                  {{ form_label(form.description, null, {label_attr: {class: 'form-label fw-semibold small'}}) }}
                  {{ form_widget(form.description, {attr: {class: 'form-control ft-input'}}) }}
                  {% if form.description.vars.errors|length > 0 %}
                    <div class="text-danger small mt-1">{{ form_errors(form.description) }}</div>
                  {% endif %}
                </div>
              </div>

              <div class="d-flex flex-wrap gap-2 mt-4">
                <button type="submit" class="btn ft-btn-primary">
                  <i class="bi bi-check-circle me-1"></i>Valider la transaction
                </button>
                <a href="{{ path('front_wallet_transactions') }}" class="btn ft-btn-outline-primary">Annuler</a>
              </div>
            {{ form_end(form) }}
          </div>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="ft-app-card ft-premium-card mb-4">
          <div class="ft-app-card-header">
            <i class="bi bi-wallet2 me-2 text-primary"></i>Wallet source
          </div>
          <div class="ft-app-card-body p-0">
            <ul class="list-group list-group-flush">
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Wallet</span>
                <span class="fw-semibold">#{{ wallet.idWallet }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Proprietaire</span>
                <span class="fw-semibold">{{ wallet.nomProprietaire }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Solde actuel</span>
                <span class="fw-semibold">{{ wallet.solde|number_format(2, ',', ' ') }} {{ wallet.devise }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">Etat</span>
                <span class="badge {{ wallet.estBloque ? 'ft-badge-danger' : 'ft-badge-success' }}">
                  {{ wallet.estBloque ? 'Bloque' : 'Operationnel' }}
                </span>
              </li>
            </ul>
          </div>
        </div>

        <div class="ft-app-card ft-premium-card">
          <div class="ft-app-card-header">
            <i class="bi bi-shield-check me-2 text-primary"></i>Controles de saisie
          </div>
          <div class="ft-app-card-body">
            <div class="ft-simple-list">
              <div class="ft-simple-item">
                <i class="bi bi-check2-circle"></i>
                <span>Le type de transaction et le montant sont obligatoires.</span>
              </div>
              <div class="ft-simple-item">
                <i class="bi bi-cash-stack"></i>
                <span>Le montant doit etre strictement positif.</span>
              </div>
              <div class="ft-simple-item">
                <i class="bi bi-shield-exclamation"></i>
                <span>Un retrait est refuse si le solde est insuffisant.</span>
              </div>
              <div class="ft-simple-item">
                <i class="bi bi-card-text"></i>
                <span>La description est optionnelle mais limitee a 500 caracteres.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
