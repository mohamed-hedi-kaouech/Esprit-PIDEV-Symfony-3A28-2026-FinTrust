{% extends 'base.html.twig' %}

{% block title %}Item{% endblock %}

{% block body %}
    <h1>Item</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ item.idItem }}</td>
            </tr>
            <tr>
                <th>Libelle</th>
                <td>{{ item.libelle }}</td>
            </tr>
            <tr>
                <th>Montant</th>
                <td>{{ item.montant }}</td>
            </tr>
            <tr>
                <th>Catégorie</th>
                <td>{{ item.categorieRel ? item.categorieRel.nomCategorie : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_item_index') }}">Retour à la liste</a>

    <a href="{{ path('app_item_edit', {'id': item.idItem}) }}">Modifier</a>

    {{ include('item/_delete_form.html.twig') }}
{% endblock %}